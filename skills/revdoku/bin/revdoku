  account_status)
    account_status
    exit 0
    ;;
  connection_status)
    connection_status
    exit 0
    ;;
  browser_login)
    browser_login_link
    exit 0
    ;;
  exchange_grant)
    exchange_grant
    exit 0
    ;;
esac

[[ -e "$PATH_TO_STORE" ]] || die "$PATH_TO_STORE does not exist"

abs_path() {
  local path="$1"
  if [[ -d "$path" ]]; then
    (cd "$path" && pwd)
  else
    local dir base
    dir="$(dirname "$path")"
    base="$(basename "$path")"
    printf "%s/%s" "$(cd "$dir" && pwd)" "$base"
  fi
}

ROOT_PATH="$(abs_path "$PATH_TO_STORE")"

default_title() {
  basename "$ROOT_PATH"
}

effective_metadata_json() {
  if [[ -d "$ROOT_PATH" ]]; then
    "$JQ_BIN" -nc \
      --arg root "$(basename "$ROOT_PATH")" \
      --argjson metadata "$METADATA_JSON" \
      '$metadata | if has("publication_root_directory") then . else . + {publication_root_directory: $root} end'
  else
    printf "%s" "$METADATA_JSON"
  fi
}

default_entrypoint() {
  printf "index.html"
}

publication_access_json() {
  "$JQ_BIN" -nc \
    --arg access_mode "$PUBLICATION_ACCESS_MODE" \
    --arg password "$PUBLICATION_PASSWORD" \
    --arg regenerate_password "$PUBLICATION_REGENERATE_PASSWORD" \
    --arg analytics_enabled "$PUBLICATION_ANALYTICS_ENABLED" \
    --arg client_events_enabled "$PUBLICATION_CLIENT_EVENTS_ENABLED" \
    --arg tracking_enabled "$PUBLICATION_TRACKING_ENABLED" \
    '{}
    + (if $access_mode != "" then {access_mode: $access_mode} else {} end)
    + (if $password != "" then {password: $password} else {} end)
    + (if $regenerate_password == "true" then {regenerate_password: true} else {} end)
    + (if $analytics_enabled != "" then {publication_analytics_enabled: ($analytics_enabled == "true")} else {} end)
    + (if $client_events_enabled != "" then {publication_client_events_enabled: ($client_events_enabled == "true")} else {} end)
    + (if $tracking_enabled != "" then {tracking_enabled: ($tracking_enabled == "true")} else {} end)'
}

has_index_file() {
  if [[ -f "$ROOT_PATH" ]]; then
    [[ "$(basename "$ROOT_PATH")" == "index.html" ]]
  else
    [[ -f "$ROOT_PATH/index.html" ]]
  fi
}

content_type_for() {
  local file="$1"
  local lower="${file##*.}"
  lower="$(printf "%s" "$lower" | tr '[:upper:]' '[:lower:]')"
  case "$lower" in
    html|htm) echo "text/html" ;;
    css|csss|scss|sass|less|styl|stylus) echo "text/css" ;;
    js|mjs|cjs) echo "text/javascript" ;;
    map) echo "application/json" ;;
    webmanifest) echo "application/manifest+json" ;;
    json) echo "application/json" ;;
    txt) echo "text/plain" ;;
    md) echo "text/markdown" ;;
    png) echo "image/png" ;;
    apng) echo "image/apng" ;;
    jpg|jpe|jpeg|jfif|pjp|pjpeg) echo "image/jpeg" ;;
    webp) echo "image/webp" ;;
    gif) echo "image/gif" ;;
    avif) echo "image/avif" ;;
    bmp) echo "image/bmp" ;;
    ico|cur) echo "image/x-icon" ;;
    heic|heics) echo "image/heic" ;;
    heif|heifs) echo "image/heif" ;;
    jp2) echo "image/jp2" ;;
    svg) echo "image/svg+xml" ;;
    woff) echo "font/woff" ;;
    woff2) echo "font/woff2" ;;
    ttf) echo "font/ttf" ;;
    otf) echo "font/otf" ;;
    wasm) echo "application/wasm" ;;
    pdf) echo "application/pdf" ;;
    xml) echo "application/xml" ;;
    rss) echo "application/rss+xml" ;;
    atom) echo "application/atom+xml" ;;
    mp4) echo "video/mp4" ;;
    mov) echo "video/quicktime" ;;
    webm) echo "video/webm" ;;
    m4v) echo "video/x-m4v" ;;
    ogv) echo "video/ogg" ;;
    avi) echo "video/x-msvideo" ;;
    mkv) echo "video/x-matroska" ;;
    mpg|mpeg) echo "video/mpeg" ;;
    ts) echo "video/mp2t" ;;
    m3u8) echo "application/vnd.apple.mpegurl" ;;
    mp3) echo "audio/mpeg" ;;
    ogg|oga) echo "audio/ogg" ;;
    wav) echo "audio/wav" ;;
    m4a) echo "audio/mp4" ;;
    aac) echo "audio/aac" ;;
    flac) echo "audio/flac" ;;
    opus) echo "audio/opus" ;;
    *) echo "application/octet-stream" ;;
  esac
}

file_size() {
  wc -c < "$1" | tr -d '[:space:]'
}

md5_base64() {
  openssl dgst -md5 -binary "$1" | base64 | tr -d '\r\n'
}

sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    openssl dgst -sha256 "$1" | awk '{print $2}'
  fi
}

relative_path_for() {
  local file="$1"
  if [[ -f "$ROOT_PATH" ]]; then
    basename "$file"
  else
    printf "%s/%s" "$(basename "$ROOT_PATH")" "${file#"$ROOT_PATH"/}"
  fi
}

local_file_for_relative_path() {
  local rel="$1"
  local root_name
  if [[ -f "$ROOT_PATH" ]]; then
    printf "%s" "$ROOT_PATH"
    return
  fi

  root_name="$(basename "$ROOT_PATH")"
  if [[ "$rel" == "$root_name/"* ]]; then
    printf "%s/%s" "$ROOT_PATH" "${rel#"$root_name"/}"
  else
    printf "%s/%s" "$ROOT_PATH" "$rel"
  fi
}

create_bucket() {
  local title payload response id
  title="$TITLE"
  [[ -n "$title" ]] || title="$(default_title)"
  payload="$(bucket_payload "$title")"
  response="$(http_json POST "/api/v1/buckets" "$payload")" || die "bucket create failed"
  id="$("$JQ_BIN" -r '.data.bucket.id // empty' <<<"$response")"
  [[ -n "$id" ]] || die "bucket create response did not include id"
  printf "%s" "$id"
}

tag_paths_json() {
  if [[ "${#TAG_PATHS[@]}" -eq 0 ]]; then
    printf "[]"
  else
    "$JQ_BIN" -nc '$ARGS.positional' --args "${TAG_PATHS[@]}"
  fi
}

bucket_payload() {
  local title="$1"
  local tag_paths metadata client_create_key
  tag_paths="$(tag_paths_json)"
  metadata="$(effective_metadata_json)"
  client_create_key="$(bucket_client_create_key "$title" "$metadata" "$tag_paths")"
  "$JQ_BIN" -nc \
    --arg title "$title" \
    --arg description "$DESCRIPTION" \
    --arg client_create_key "$client_create_key" \
    --argjson metadata "$metadata" \
    --argjson tag_paths "$tag_paths" \
    '{
      bucket: (
        {title: $title, metadata: ($metadata + {"_revdoku_client_create_key": $client_create_key})}
        + (if $description != "" then {description: $description} else {} end)
        + (if ($tag_paths | length) > 0 then {tag_paths: $tag_paths} else {} end)
      )
    }'
}

bucket_client_create_key() {
  local title="$1"
  local metadata="$2"
  local tag_paths="$3"
  local digest
  digest="$(printf "%s\n%s\n%s\n%s\n%s" "$title" "$ROOT_PATH" "$metadata" "$tag_paths" "$AGENT_RUN_ID" | openssl dgst -sha256 -hex | awk '{print $2}')"
  printf "cli:%s" "$digest"
}

bucket_update_payload() {
  local tag_paths
  tag_paths="$(tag_paths_json)"
  "$JQ_BIN" -nc \
    --arg title "$TITLE" \
    --arg description "$DESCRIPTION" \
    --argjson metadata "$METADATA_JSON" \
    --argjson tag_paths "$tag_paths" \
    '{
      bucket: (
        {}
        + (if $title != "" then {title: $title} else {} end)
        + (if $description != "" then {description: $description} else {} end)
        + (if ($metadata | length) > 0 then {metadata: $metadata} else {} end)
        + (if ($tag_paths | length) > 0 then {tag_paths: $tag_paths} else {} end)
      )
    }'
}

bucket_update_needed() {
  [[ "$METADATA_JSON" != "{}" || -n "$DESCRIPTION" || "${#TAG_PATHS[@]}" -gt 0 ]]
}

put_direct_upload() {
  local upload_json="$1"
  local file="$2"
  local url header_args=() body_file status curl_status attempt delay
  LAST_DIRECT_UPLOAD_STATUS=""
  url="$("$JQ_BIN" -r '.url // empty' <<<"$upload_json")"
  [[ -n "$url" ]] || return 1

  while IFS=$'\t' read -r key value; do
    [[ -n "$key" ]] || continue
    header_args+=(-H "${key}: ${value}")
  done < <("$JQ_BIN" -r '.headers // {} | to_entries[] | [.key, .value] | @tsv' <<<"$upload_json")

  attempt=0
  while true; do
    body_file="$(mktemp)"
    if status="$(curl -sS -o "$body_file" -w "%{http_code}" -X PUT "${header_args[@]}" --data-binary "@${file}" "$url")"; then
      curl_status=0
    else
      curl_status=$?
    fi

    if [[ "$curl_status" == "0" ]] && http_status_success "$status"; then
      LAST_DIRECT_UPLOAD_STATUS="$status"
      rm -f "$body_file"
      return 0
    fi

    if (( attempt < DIRECT_UPLOAD_MAX_ATTEMPTS )) && { [[ "$curl_status" != "0" ]] || http_status_retryable "$status"; }; then
      attempt=$((attempt + 1))
      delay="$(retry_delay_for_attempt "$attempt")"
      if [[ "$curl_status" != "0" ]]; then
        echo "Direct upload network error; retrying in ${delay}s (${attempt}/${DIRECT_UPLOAD_MAX_ATTEMPTS})..." >&2
      else
        echo "Direct upload HTTP $status; retrying in ${delay}s (${attempt}/${DIRECT_UPLOAD_MAX_ATTEMPTS})..." >&2
      fi
      rm -f "$body_file"
      sleep "$delay"
      continue
    fi

    if [[ "$curl_status" != "0" ]]; then
      LAST_DIRECT_UPLOAD_STATUS=""
      echo "error: direct upload failed (curl exit $curl_status)" >&2
    else
      LAST_DIRECT_UPLOAD_STATUS="$status"
      echo "error: direct upload failed (HTTP $status)" >&2
      if [[ -s "$body_file" ]]; then
        cat "$body_file" >&2
      fi
    fi
    rm -f "$body_file"
    return 1
  done
}

put_publish_session_upload() {
  local session_id="$1"
  local rel="$2"
  local upload_json="$3"
  local file="$4"
  local refresh_response refreshed_upload

  if put_direct_upload "$upload_json" "$file"; then
    return 0
  fi

  echo "Upload URL failed for $rel; refreshing upload URL and retrying." >&2
  refresh_response="$(http_json POST "/api/v1/publish_sessions/${session_id}/uploads/refresh" "{}")" || return 1
  refreshed_upload="$("$JQ_BIN" -c --arg path "$rel" '.data.publish_session.uploads[]? | select(.path == $path) | .upload' <<<"$refresh_response" | head -n 1)"
  if [[ -z "$refreshed_upload" || "$refreshed_upload" == "null" ]]; then
    echo "Upload for $rel was already accepted by Revdoku." >&2
    return 0
  fi

  put_direct_upload "$refreshed_upload" "$file"
}

publish_session_retryable_error() {
  case "${LAST_ERROR_CODE:-}" in
    PUBLISH_SESSION_STALE|PUBLISH_SESSION_EXPIRED|PUBLISH_SESSION_NOT_PENDING)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

publication_limit_error() {
  [[ "${LAST_ERROR_CODE:-}" == "PUBLICATION_LIMIT_REACHED" ]]
}

private_publication_limit_error() {
  [[ "${LAST_ERROR_CODE:-}" == "PRIVATE_PUBLICATION_LIMIT_REACHED" ]]
}

publish_session_fallback_allowed() {
  case "${LAST_HTTP_STATUS:-}" in
    401|403)
      return 1
      ;;
  esac

  case "${LAST_ERROR_CODE:-}" in
    PUBLICATION_LIMIT_REACHED|PRIVATE_PUBLICATION_LIMIT_REACHED|PUBLIC_STORAGE_NOT_CONFIGURED|PRIVATE_PUBLICATION_STORAGE_NOT_CONFIGURED|UNAUTHORIZED|FORBIDDEN|BUCKET_ACCESS_DENIED|BUCKET_PERMISSION_DENIED|BUCKET_LIMIT_REACHED|STORAGE_QUOTA_EXCEEDED)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

print_publication_limit_guidance() {
  echo "Live public site limit reached for this account." >&2
  if [[ -n "$LAST_PUBLISH_SESSION_BUCKET_ID" ]]; then
    echo "Private bucket storage is still available: $LAST_PUBLISH_SESSION_BUCKET_ID" >&2
  fi
  echo "To update an existing public site, rerun with --bucket-id for that public bucket; republishing keeps the same URL and does not use another live-site slot." >&2
  echo "To publish a new site, list current public buckets with --list-public-buckets, then ask before unpublishing one with --unpublish. To change plan capacity, visit Revdoku in the browser." >&2
}

print_private_publication_limit_guidance() {
  echo "Protected website limit reached for this account." >&2
  if [[ -n "$LAST_PUBLISH_SESSION_BUCKET_ID" ]]; then
    echo "Private bucket storage is still available: $LAST_PUBLISH_SESSION_BUCKET_ID" >&2
  fi
  echo "Protected websites require available Pro protected-site capacity. Publish publicly, unpublish another protected website, or update the plan." >&2
}

upload_file_direct() {
  local bucket_id="$1"
  local file="$2"
  local file_list
  file_list="$(mktemp)"
  printf "%s\0" "$file" > "$file_list"
  store_bucket_session_upload "$bucket_id" "$file_list"
  local status=$?
  rm -f "$file_list"
  return "$status"
}

upload_file() {
  local bucket_id="$1"
  local file="$2"
  local rel
  rel="$(relative_path_for "$file")"
  echo "Uploading $rel" >&2

  upload_file_direct "$bucket_id" "$file"
}

bucket_upload_session_manifest_json() {
  publish_session_manifest_json "$1"
}

bucket_upload_session_client_key() {
  local bucket_id="$1"
  local manifest_json="$2"
  local digest
  if [[ -n "$BUCKET_UPLOAD_CLIENT_SESSION_KEY" ]]; then
    printf "%s" "$BUCKET_UPLOAD_CLIENT_SESSION_KEY"
    return 0
  fi
  digest="$(printf "%s:%s" "$bucket_id" "$manifest_json" | openssl dgst -sha256 -hex | awk '{print $2}')"
  printf "cli:%s:%s" "$bucket_id" "$digest"
}

bucket_upload_session_payload() {
  local client_session_key="$1"
  local expected_file_count="$2"
  "$JQ_BIN" -nc \
    --arg client_session_key "$client_session_key" \
    --argjson expected_file_count "$expected_file_count" \
    '{
      client_session_key: $client_session_key,
      expected_file_count: $expected_file_count
    }'
}

prepare_bucket_upload_descriptors() {
  local bucket_id="$1"
  local session_id="$2"
  local batch_json="$3"
  local payload
  payload="$("$JQ_BIN" -nc --argjson files "$batch_json" '{files: $files}')"
  http_json POST "/api/v1/buckets/${bucket_id}/upload_sessions/${session_id}/uploads" "$payload"
}

finalize_bucket_upload_session() {
  local bucket_id="$1"
  local session_id="$2"
  local complete="${3:-true}"
  local payload response pending attempts=0 remaining
  local max_attempts="${REVDOKU_FINALIZE_MAX_ATTEMPTS:-1000}"
  [[ -n "$session_id" ]] || return 0
  "$JQ_BIN" -nc --argjson complete "$complete" '{complete:$complete}' | {
    payload="$(cat)"
    while :; do
      response="$(http_json POST "/api/v1/buckets/${bucket_id}/upload_sessions/${session_id}/finalize" "$payload")" || return 1
      pending="$("$JQ_BIN" -r '.data.finalize_pending // false' <<<"$response")"
      [[ "$pending" == "true" && "$complete" == "true" ]] || return 0
      attempts=$((attempts + 1))
      remaining="$("$JQ_BIN" -r '.data.remaining_files_count // .data.bucket_upload_session.remaining_files_count // empty' <<<"$response" 2>/dev/null || true)"
      if (( attempts == 1 || attempts % 5 == 0 )); then
        if [[ -n "$remaining" && "$remaining" != "null" ]]; then
          echo "Still finalizing ${remaining} file(s)… (attempt ${attempts})" >&2
        else
          echo "Still finalizing files… (attempt ${attempts})" >&2
        fi
      fi
      if (( attempts >= max_attempts )); then
        echo "Timed out finalizing the upload session after ${attempts} attempts (~$((attempts * 2 / 60)) min)." >&2
        echo "Files may still be processing in the background; re-run the command to resume." >&2
        return 1
      fi
      sleep 2
    done
  }
}

finalize_bucket_upload_session_batch() {
  local bucket_id="$1"
  local session_id="$2"
  local limit="${3:-100}"
  local attempts=0 missing_entry_json missing_path
  [[ -n "$session_id" ]] || return 0
  "$JQ_BIN" -nc --argjson limit "$limit" '{limit:$limit}' | {
    local payload
    payload="$(cat)"
    while :; do
      if http_json POST "/api/v1/buckets/${bucket_id}/upload_sessions/${session_id}/finalize_batch" "$payload" >/dev/null; then
        return 0
      fi

      if [[ "${LAST_ERROR_CODE:-}" == "DIRECT_UPLOAD_NOT_FOUND" && "$attempts" -lt "$BUCKET_UPLOAD_DESCRIPTOR_BATCH_SIZE" ]]; then
        missing_entry_json="$LAST_ERROR_DETAILS_JSON"
        missing_path="$("$JQ_BIN" -r '.path // empty' <<<"$missing_entry_json" 2>/dev/null || true)"
        if [[ -n "$missing_path" ]] && upload_bucket_session_missing_entry "$bucket_id" "$session_id" "$missing_entry_json"; then
          attempts=$((attempts + 1))
          echo "Retrying bucket upload batch finalize after refreshing $missing_path." >&2
          continue
        fi
      fi

      return 1
    done
  }
}

upload_bucket_session_missing_entry() {
  local bucket_id="$1"
  local session_id="$2"
  local entry_json="$3"
  local rel file response upload_json

  rel="$("$JQ_BIN" -r '.path // empty' <<<"$entry_json" 2>/dev/null || true)"
  [[ -n "$rel" ]] || return 1
  file="$(local_file_for_relative_path "$rel")"
  [[ -f "$file" ]] || {
    echo "error: upload session asked to refresh unknown upload path: $rel" >&2
    return 1
  }

  echo "Refreshing missing direct upload for $rel." >&2
  response="$(prepare_bucket_upload_descriptors "$bucket_id" "$session_id" "[$entry_json]")" || return 1
  upload_json="$("$JQ_BIN" -c '.data.uploads[0].upload // empty' <<<"$response")"
  [[ -n "$upload_json" && "$upload_json" != "null" ]] || return 1

  echo "Uploading $rel" >&2
  put_direct_upload "$upload_json" "$file"
}

store_bucket_session_upload() {
  local bucket_id="$1"
  local file_list="$2"
  local manifest_json payload response session_id upload_line rel upload_json file batch_json batch_response expected_file_count client_session_key failed=0 finalized=0 entry_json refresh_response uploaded_index=0
  manifest_json="$(bucket_upload_session_manifest_json "$file_list")"
  expected_file_count="$("$JQ_BIN" -r 'length' <<<"$manifest_json")"
  client_session_key="$(bucket_upload_session_client_key "$bucket_id" "$manifest_json")"
  payload="$(bucket_upload_session_payload "$client_session_key" "$expected_file_count")"
  response="$(http_json POST "/api/v1/buckets/${bucket_id}/upload_sessions" "$payload")" || return 1
  session_id="$("$JQ_BIN" -r '.data.bucket_upload_session.id // empty' <<<"$response")"
  [[ -n "$session_id" ]] || die "bucket upload session response did not include id"
  echo "Bucket upload session: $session_id" >&2

  while IFS= read -r batch_json; do
    [[ -n "$batch_json" && "$batch_json" != "[]" ]] || continue
    batch_response="$(prepare_bucket_upload_descriptors "$bucket_id" "$session_id" "$batch_json")" || {
      failed=1
      break
    }
    while IFS= read -r upload_line; do
      [[ -n "$upload_line" ]] || continue
      rel="$("$JQ_BIN" -r '.path' <<<"$upload_line")"
      upload_json="$("$JQ_BIN" -c '.upload' <<<"$upload_line")"
      file="$(local_file_for_relative_path "$rel")"
      [[ -f "$file" ]] || {
        echo "error: upload session asked for unknown upload path: $rel" >&2
        failed=1
        break
      }
      uploaded_index=$((uploaded_index + 1))
      echo "Uploading ${uploaded_index}/${expected_file_count}: $rel" >&2
      if ! put_direct_upload "$upload_json" "$file"; then
        if [[ "${LAST_DIRECT_UPLOAD_STATUS:-}" == "403" || "${LAST_DIRECT_UPLOAD_STATUS:-}" == "404" ]]; then
          entry_json="$("$JQ_BIN" -c --arg rel "$rel" 'map(select(.path == $rel))[0] // empty' <<<"$batch_json")"
          if [[ -n "$entry_json" ]] && refresh_response="$(prepare_bucket_upload_descriptors "$bucket_id" "$session_id" "[$entry_json]")"; then
            upload_json="$("$JQ_BIN" -c '.data.uploads[0].upload // empty' <<<"$refresh_response")"
            if [[ -n "$upload_json" ]] && put_direct_upload "$upload_json" "$file"; then
              continue
            fi
          fi
        fi
        echo "error: upload failed for $rel" >&2
        failed=1
        break
      fi
    done < <("$JQ_BIN" -c '.data.uploads[]?' <<<"$batch_response")
    [[ "$failed" == "0" ]] || break

    if ! finalize_bucket_upload_session_batch "$bucket_id" "$session_id" "$BUCKET_UPLOAD_DESCRIPTOR_BATCH_SIZE"; then
      failed=1
      break
    fi
  done < <("$JQ_BIN" -c --argjson size "$BUCKET_UPLOAD_DESCRIPTOR_BATCH_SIZE" 'range(0; length; $size) as $i | .[$i:($i + $size)]' <<<"$manifest_json")

  if [[ "$failed" == "0" ]] && finalize_bucket_upload_session "$bucket_id" "$session_id" true; then
    finalized=1
  else
    failed=1
  fi
  if [[ "$finalized" != "1" ]]; then
    finalize_bucket_upload_session "$bucket_id" "$session_id" false >/dev/null 2>&1 || true
  fi
  return "$failed"
}

publish_bucket() {
  local bucket_id="$1"
  local payload response response_file url entrypoint metadata access
  entrypoint="$(default_entrypoint)"
  metadata="$(effective_metadata_json)"
  access="$(publication_access_json)"
  if [[ "$PERMANENT_PUBLICATION" == "true" ]]; then
    payload="$("$JQ_BIN" -nc --arg entrypoint "$entrypoint" --argjson metadata "$metadata" --argjson access "$access" '{permanent:true, entrypoint:$entrypoint, metadata:$metadata} + $access')"
  else
    payload="$("$JQ_BIN" -nc --arg entrypoint "$entrypoint" --argjson expires_in_days "$EXPIRES_IN_DAYS" --argjson metadata "$metadata" --argjson access "$access" '{expires_in_days:$expires_in_days, entrypoint:$entrypoint, metadata:$metadata} + $access')"
  fi
  response_file="$(mktemp)"
  if ! http_json POST "/api/v1/buckets/${bucket_id}/publication" "$payload" > "$response_file"; then
    rm -f "$response_file"
    if [[ "${LAST_ERROR_CODE:-}" == "PUBLIC_STORAGE_NOT_CONFIGURED" ]]; then
      echo "Public publishing is not configured for this Revdoku deployment." >&2
      echo "Private bucket storage is still available: $bucket_id" >&2
    elif [[ "${LAST_ERROR_CODE:-}" == "PRIVATE_PUBLICATION_STORAGE_NOT_CONFIGURED" ]]; then
      echo "Protected website publishing is not configured for this Revdoku deployment." >&2
      echo "Private bucket storage is still available: $bucket_id" >&2
    elif publication_limit_error; then
      LAST_PUBLISH_SESSION_BUCKET_ID="$bucket_id"
      print_publication_limit_guidance
    elif private_publication_limit_error; then
      LAST_PUBLISH_SESSION_BUCKET_ID="$bucket_id"
      print_private_publication_limit_guidance
    fi
    die "bucket publish failed"
  fi
  response="$(cat "$response_file")"
  rm -f "$response_file"
  response="$(resolve_async_publication_response "$response")" || die "bucket publish did not finish"
  url="$("$JQ_BIN" -r '.data.publication.public_url // empty' <<<"$response")"
  [[ -n "$url" ]] || die "publish response did not include url"
  print_public_profile_listing_hint_from_response "$response"
  print_publication_access_hint_from_response "$response"
  printf "%s\n" "$url"
}

publish_session_manifest_json() {
  local file_list="$1"
  local manifest_lines rel filename content_type size checksum sha256
  manifest_lines="$(mktemp)"
  while IFS= read -r -d '' file; do
    rel="$(relative_path_for "$file")"
    filename="$(basename "$file")"
    content_type="$(content_type_for "$file")"
    size="$(file_size "$file")"
    checksum="$(md5_base64 "$file")"
    sha256="$(sha256_file "$file")"
    "$JQ_BIN" -nc \
      --arg path "$rel" \
      --argjson byte_size "$size" \
      --arg content_type "$content_type" \
      --arg checksum "$checksum" \
      --arg sha256 "$sha256" \
      '{path:$path, byte_size:$byte_size, content_type:$content_type, checksum:$checksum, sha256:$sha256}' >> "$manifest_lines"
  done < "$file_list"
  "$JQ_BIN" -sc '.' "$manifest_lines"
  rm -f "$manifest_lines"
}

publish_session_payload() {
  local manifest_json="$1"
  local title tag_paths expires_in_days entrypoint metadata access
  title="$TITLE"
  [[ -n "$title" ]] || title="$(default_title)"
  tag_paths="$(tag_paths_json)"
  expires_in_days="${EXPIRES_IN_DAYS:-7}"
  entrypoint="$(default_entrypoint)"
  metadata="$(effective_metadata_json)"
  access="$(publication_access_json)"
  "$JQ_BIN" -nc \
    --arg title "$title" \
    --arg description "$DESCRIPTION" \
    --arg bucket_id "$BUCKET_ID" \
    --arg permanent "$PERMANENT_PUBLICATION" \
    --arg entrypoint "$entrypoint" \
    --argjson expires_in_days "$expires_in_days" \
    --argjson metadata "$metadata" \
    --argjson access "$access" \
    --argjson tag_paths "$tag_paths" \
    --argjson files "$manifest_json" \
    '{
      title: $title,
      bucket_title: $title,
      entrypoint: $entrypoint,
      metadata: $metadata,
      files: $files
    }
    + (if $bucket_id != "" then {bucket_id: $bucket_id} else {} end)
    + (if $description != "" then {bucket_description: $description} else {} end)
    + (if ($tag_paths | length) > 0 then {bucket_tag_paths: $tag_paths} else {} end)
    + (if $permanent == "true" then {permanent: true} else {expires_in_days: $expires_in_days} end)
    + $access'
}

publish_session_file_for_path() {
  local rel="$1"
  local_file_for_relative_path "$rel"
}

publish_bucket_session_attempt() {
  local file_list="$1"
  local manifest_json payload response response_file session_id bucket_id upload_line rel upload_json file finalize_url final_response final_response_file url
  manifest_json="$(publish_session_manifest_json "$file_list")"
  payload="$(publish_session_payload "$manifest_json")"
  response_file="$(mktemp)"
  if ! http_json POST "/api/v1/publish_sessions" "$payload" > "$response_file"; then
    rm -f "$response_file"
    return 1
  fi
  response="$(cat "$response_file")"
  rm -f "$response_file"

  session_id="$("$JQ_BIN" -r '.data.publish_session.id // empty' <<<"$response")"
  bucket_id="$("$JQ_BIN" -r '.data.publish_session.bucket_id // empty' <<<"$response")"
  LAST_PUBLISH_SESSION_BUCKET_ID="$bucket_id"
  [[ -n "$session_id" ]] || {
    die "publish session response did not include id"
  }
  [[ -n "$bucket_id" ]] && {
    echo "Bucket: $bucket_id" >&2
    echo "Saved draft bucket before live publish: $bucket_id" >&2
  }
  echo "Publish session: $session_id" >&2

  local upload_total upload_index=0
  upload_total="$("$JQ_BIN" -r '[.data.publish_session.uploads[]?] | length' <<<"$response")"
  [[ -n "$upload_total" && "$upload_total" != "null" ]] || upload_total=0
  while IFS= read -r upload_line; do
    [[ -n "$upload_line" ]] || continue
    rel="$("$JQ_BIN" -r '.path' <<<"$upload_line")"
    upload_json="$("$JQ_BIN" -c '.upload' <<<"$upload_line")"
    file="$(publish_session_file_for_path "$rel")"
    [[ -f "$file" ]] || {
      die "publish session asked for unknown upload path: $rel"
    }
    upload_index=$((upload_index + 1))
    echo "Uploading ${upload_index}/${upload_total}: $rel" >&2
    if ! put_publish_session_upload "$session_id" "$rel" "$upload_json" "$file"; then
      return 1
    fi
  done < <("$JQ_BIN" -c '.data.publish_session.uploads[]?' <<<"$response")

  finalize_url="$("$JQ_BIN" -r '.data.finalize.url // empty' <<<"$response")"
  [[ -n "$finalize_url" ]] || {
    die "publish session response did not include finalize URL"
  }
  final_response_file="$(mktemp)"
  if ! http_json POST "$finalize_url" "{}" > "$final_response_file"; then
    rm -f "$final_response_file"
    return 1
  fi
  final_response="$(cat "$final_response_file")"
  rm -f "$final_response_file"
  final_response="$(resolve_async_publication_response "$final_response")" || return 1

  url="$("$JQ_BIN" -r '.data.publication.public_url // empty' <<<"$final_response")"
  [[ -n "$url" ]] || die "publish response did not include url"
  print_public_profile_listing_hint_from_response "$final_response"
  print_publication_access_hint_from_response "$final_response"
  printf "%s\n" "$url"
}

publish_bucket_session() {
  local file_list publish_url publish_url_file
  file_list="$(mktemp)"
  if ! collect_files > "$file_list"; then
    rm -f "$file_list"
    return 1
  fi
  if [[ ! -s "$file_list" ]]; then
    rm -f "$file_list"
    die "no files found to publish after safety exclusions"
  fi

  publish_url_file="$(mktemp)"
  if publish_bucket_session_attempt "$file_list" > "$publish_url_file"; then
    publish_url="$(cat "$publish_url_file")"
    rm -f "$publish_url_file"
    rm -f "$file_list"
    printf "%s\n" "$publish_url"
    return 0
  fi

  if publish_session_retryable_error; then
    echo "Publish session became stale or expired; starting a fresh publish session." >&2
    if publish_bucket_session_attempt "$file_list" > "$publish_url_file"; then
      publish_url="$(cat "$publish_url_file")"
      rm -f "$publish_url_file"
      rm -f "$file_list"
      printf "%s\n" "$publish_url"
      return 0
    fi
  fi

  rm -f "$publish_url_file"
  rm -f "$file_list"
  return 1
}

bucket_id_for_storage() {
  if [[ -n "$BUCKET_ID" ]]; then
    if bucket_update_needed; then
      local payload
      payload="$(bucket_update_payload)"
      http_json PATCH "/api/v1/buckets/${BUCKET_ID}" "$payload" >/dev/null
    fi
    printf "%s" "$BUCKET_ID"
  else
    create_bucket
  fi
}

store_bucket() {
  local bucket_id bucket_id_file file_list
  file_list="$(mktemp)"
  if ! collect_files > "$file_list"; then
    rm -f "$file_list"
    return 1
  fi
  if [[ ! -s "$file_list" ]]; then
    rm -f "$file_list"
    die "no files found to store after safety exclusions"
  fi

  bucket_id_file="$(mktemp)"
  if ! bucket_id_for_storage > "$bucket_id_file"; then
    rm -f "$bucket_id_file" "$file_list"
    return 1
  fi
  bucket_id="$(cat "$bucket_id_file")"
  rm -f "$bucket_id_file"
  [[ -n "$bucket_id" ]] || {
    rm -f "$file_list"
    die "bucket id is required before uploading files"
  }
  echo "Bucket: $bucket_id" >&2
  echo "Saved draft bucket: $bucket_id" >&2
  store_bucket_session_upload "$bucket_id" "$file_list" || {
    rm -f "$file_list"
    return 1
  }
  rm -f "$file_list"
  printf "%s" "$bucket_id"
}

verify_published_url() {
  local url="$1"
  curl -fsSL --max-time 15 "$url" -o /dev/null || {
    echo "error: published URL was created but did not respond: $url" >&2
    return 1
  }
}

collect_files() {
  if [[ -f "$ROOT_PATH" ]]; then
    if should_skip_storage_path "$ROOT_PATH"; then
      die "refusing to store file from Revdoku upload safety list: $(basename "$ROOT_PATH")"
    fi
    printf "%s\0" "$ROOT_PATH"
    return
  fi

  find "$ROOT_PATH" \
    \( -type d \( -name ".git" -o -name ".hg" -o -name ".svn" -o -name ".revdoku" -o -name ".terraform" -o -name ".cache" -o -name ".parcel-cache" -o -name ".turbo" -o -name ".vite" -o -name "node_modules" \) -prune \) \
    -o -type f -print0 |
    while IFS= read -r -d '' file; do
      if should_skip_storage_path "$file"; then
        echo "Skipping file from Revdoku upload safety list: $(relative_path_for "$file")" >&2
        continue
      fi
      printf "%s\0" "$file"
    done
}

should_skip_storage_path() {
  local file="$1"
  local rel name lower_rel lower_name part extension
  rel="$(relative_path_for "$file")"
  name="$(basename "$file")"
  lower_rel="$(printf "%s" "$rel" | tr '[:upper:]' '[:lower:]')"
  lower_name="$(printf "%s" "$name" | tr '[:upper:]' '[:lower:]')"

  IFS='/' read -r -a path_parts <<< "$lower_rel"
  for part in "${path_parts[@]}"; do
    case "$part" in
      .ds_store|.git|.hg|.svn|.revdoku|.terraform|.cache|.parcel-cache|.turbo|.vite|node_modules)
        return 0
        ;;
      .env|.npmrc|.pypirc|.netrc|id_rsa|id_rsa.pub|id_dsa|id_dsa.pub|id_ecdsa|id_ecdsa.pub|id_ed25519|id_ed25519.pub)
        return 0
        ;;
      .env.*|env.local|env.production|env.staging|env.development|env.test)
        return 0
        ;;
      *.pem|*.key|*.p12|*.pfx|*.crt|*.cer|*.der|*.kdb|*.jks|*.mobileprovision|api-token.*|api_key.*|credentials.*|credential.*|secrets.*|secret.*|private-key.*|private_key.*)
        return 0
        ;;
    esac
  done

  extension="${lower_name##*.}"
  if [[ "$lower_name" == *.* && "$extension" != "$lower_name" ]]; then
    case ".${extension}" in
      .exe|.com|.scr|.pif|.cpl|.dll|.sys|.drv|.msi|.msp|.app|.dmg|.pkg|.deb|.rpm|.apk|.ipa|.jar|.jnlp|.run|.bin|.lnk)
        return 0
        ;;
    esac
  fi

  return 1
}

publish_url_file=""
bucket_id_file=""

if [[ "$PUBLISH" == "true" ]]; then
  if ! has_index_file; then
    echo "No index.html found; Revdoku will publish a generated file listing." >&2
  fi
  publish_url_file="$(mktemp)"
  if publish_bucket_session > "$publish_url_file"; then
    publish_url="$(cat "$publish_url_file")"
    rm -f "$publish_url_file"
    verify_published_url "$publish_url"
    echo "Published live: $publish_url" >&2
    print_terminal_link_hint
    printf "%s\n" "$publish_url"
    exit 0
  fi
  rm -f "$publish_url_file"
  if publication_limit_error && [[ -z "$BUCKET_ID" && -n "$LAST_PUBLISH_SESSION_BUCKET_ID" ]]; then
    BUCKET_ID="$LAST_PUBLISH_SESSION_BUCKET_ID"
  fi
  if [[ "$UPLOAD_MODE" == "direct" ]]; then
    publication_limit_error && print_publication_limit_guidance
    private_publication_limit_error && print_private_publication_limit_guidance
    die "direct publish session failed"
  fi
  if ! publish_session_fallback_allowed; then
    publication_limit_error && print_publication_limit_guidance
    private_publication_limit_error && print_private_publication_limit_guidance
    [[ "${LAST_ERROR_CODE:-}" == "PRIVATE_PUBLICATION_STORAGE_NOT_CONFIGURED" ]] && echo "Protected website publishing is not configured for this Revdoku deployment." >&2
    die "direct publish session failed"
  fi
  echo "Direct publish session failed; retrying with bucket upload session." >&2
fi

bucket_id_file="$(mktemp)"
if ! store_bucket > "$bucket_id_file"; then
  rm -f "$bucket_id_file"
  die "bucket store failed"
fi
bucket_id="$(cat "$bucket_id_file")"
rm -f "$bucket_id_file"
echo "Saved draft bucket: $bucket_id" >&2

if [[ "$PUBLISH" == "true" ]]; then
  publish_url_file="$(mktemp)"
  if ! publish_bucket "$bucket_id" > "$publish_url_file"; then
    rm -f "$publish_url_file"
    die "bucket publish failed"
  fi
  publish_url="$(cat "$publish_url_file")"
  rm -f "$publish_url_file"
  verify_published_url "$publish_url"
  echo "Published live: $publish_url" >&2
  echo "Manage in Revdoku: $BASE_URL/buckets/view?id=$bucket_id" >&2
  print_terminal_link_hint
  printf "%s\n" "$publish_url"
else
  # Show the owner a clickable dashboard link, not just the bkt_ id. stdout stays
  # the bucket id so scripts and --bucket-id reuse keep working.
  echo "View in Revdoku: $BASE_URL/buckets/view?id=$bucket_id" >&2
  print_terminal_link_hint
  printf "%s\n" "$bucket_id"
fi
