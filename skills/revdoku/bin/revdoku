#!/usr/bin/env bash
set -euo pipefail

DEFAULT_URL="https://app.revdoku.com"
CREDENTIALS_PATH="${REVDOKU_CREDENTIALS:-${HOME}/.revdoku/credentials}"
DEFAULT_BUCKET_PATH="${REVDOKU_DEFAULT_BUCKET_FILE:-${CREDENTIALS_PATH}.bucket}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

BASE_URL="${REVDOKU_URL:-$DEFAULT_URL}"
API_KEY="${REVDOKU_API_KEY:-}"
TITLE="${REVDOKU_BUCKET_TITLE:-}"
DESCRIPTION="${REVDOKU_BUCKET_DESCRIPTION:-}"
EXPIRES_IN_DAYS="${REVDOKU_EXPIRES_IN_DAYS:-}"
UPLOAD_MODE="${REVDOKU_UPLOAD_MODE:-auto}"
BUCKET_ID="${REVDOKU_BUCKET_ID:-}"
METADATA_JSON="${REVDOKU_BUCKET_METADATA:-}"
PUBLISH="${REVDOKU_PUBLISH:-false}"
PERMANENT_PUBLICATION="${REVDOKU_PERMANENT_PUBLICATION:-true}"
PUBLICATION_ACCESS_MODE="${REVDOKU_PUBLICATION_ACCESS_MODE:-}"
PUBLICATION_PASSWORD="${REVDOKU_PUBLICATION_PASSWORD:-}"
PUBLICATION_REGENERATE_PASSWORD="${REVDOKU_PUBLICATION_REGENERATE_PASSWORD:-false}"
RESTORE_VERSION_ID="${REVDOKU_RESTORE_VERSION_ID:-}"
RESTORE_COMMENT="${REVDOKU_RESTORE_COMMENT:-}"
GRANT_TOKEN="${REVDOKU_GRANT_TOKEN:-}"
BROWSER_LOGIN_PATH="${REVDOKU_BROWSER_LOGIN_PATH:-/buckets}"
TAG_PATHS=()
AGENT_NAME="${REVDOKU_AGENT_NAME:-cli}"
AGENT_CLIENT="${REVDOKU_AGENT_CLIENT:-revdoku}"
AGENT_VERSION="${REVDOKU_AGENT_VERSION:-0.1.0}"
AGENT_RUN_ID="${REVDOKU_AGENT_RUN_ID:-}"
AGENT_PROJECT="${REVDOKU_AGENT_PROJECT:-}"
AGENT_TASK="${REVDOKU_AGENT_TASK:-}"
LOGIN="false"
ACTION="store"
PATH_TO_STORE=""
LAST_PUBLISH_SESSION_BUCKET_ID=""
LAST_HTTP_STATUS=""
LAST_ERROR_CODE=""
LAST_ERROR_MESSAGE=""

die() {
  echo "error: $1" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "requires $1"
}

usage() {
  cat <<USAGE
Usage: revdoku [options] PATH

Options:
  --api-key KEY             Revdoku API key. Defaults to REVDOKU_API_KEY or $CREDENTIALS_PATH.
  --url URL                 Revdoku app URL. Defaults to REVDOKU_URL or $DEFAULT_URL.
  --title TITLE             Bucket title.
  --description TEXT        Short bucket description.
  --tag-path PATH           Add a bucket label such as website or projects/work. Can be repeated.
  --bucket-id ID         Store into an existing Revdoku bucket instead of creating a new one.
                            Defaults to a bucket remembered from a selected-bucket grant.
  --metadata JSON           Optional JSON for agent lookup, for example {"project":"site"}.
  --publish                 Publish as a permanent website after storing files. Defaults to public.
  --access-mode MODE        Website access mode: public, password, or password_ask_info. Existing sites keep their mode unless changed.
  --protected               Alias for --access-mode password.
  --private                 Alias for --access-mode password.
  --public                  Alias for --access-mode public.
  --password PASSWORD       Password for --access-mode password. Never sent in a URL.
  --generate-password       Generate or regenerate the protected website password.
  --unpublish               Unpublish --bucket-id while keeping its reserved URL for later republish.
  --archive                 Archive --bucket-id. Published buckets must be unpublished first.
  --unarchive               Restore archived --bucket-id to the active bucket list.
  --delete-bucket           Permanently delete archived unpublished --bucket-id.
  --expires-in-days DAYS    Advanced: expire the website after DAYS instead of keeping it permanent.
  --login                   Request an email code and save an API key to $CREDENTIALS_PATH.
  --list-buckets         Print available buckets and metadata as JSON.
  --list-versions           Print version history for --bucket-id as JSON.
  --restore-version ID      Restore a bucket version as a new latest version; requires --bucket-id.
  --restore-comment TEXT    Optional comment for --restore-version.
  --list-public-buckets  Print active website links as JSON.
  --account-status          Print account, plan, and storage status as JSON.
  --dashboard-link          Print a one-time browser login link for the Revdoku dashboard.
  --library-link            Print a one-time browser login link for Library settings.
  --access-link             Print a one-time browser login link for Account > Access.
  --public-handle-link      Print a one-time browser login link for Account public handle settings.
  --browser-login PATH      Print a one-time browser login link for an internal Revdoku path.
                            Browser login links are disabled when 2FA is enabled or required.
  --upload-mode MODE        auto, direct, or multipart. Defaults to auto.
  --exchange-grant TOKEN    Exchange a one-time app grant and save the API key.
  --grant-token TOKEN       Alias for --exchange-grant.
  -h, --help                Show this help.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --api-key)
      [[ $# -ge 2 ]] || die "--api-key requires a value"
      API_KEY="$2"
      shift 2
      ;;
    --url)
      [[ $# -ge 2 ]] || die "--url requires a value"
      BASE_URL="$2"
      shift 2
      ;;
    --title)
      [[ $# -ge 2 ]] || die "--title requires a value"
      TITLE="$2"
      shift 2
      ;;
    --description)
      [[ $# -ge 2 ]] || die "--description requires a value"
      DESCRIPTION="$2"
      shift 2
      ;;
    --tag-path)
      [[ $# -ge 2 ]] || die "--tag-path requires a value"
      TAG_PATHS+=("$2")
      shift 2
      ;;
    --bucket-id)
      [[ $# -ge 2 ]] || die "--bucket-id requires a value"
      BUCKET_ID="$2"
      shift 2
      ;;
    --metadata)
      [[ $# -ge 2 ]] || die "--metadata requires a JSON object"
      METADATA_JSON="$2"
      shift 2
      ;;
    --publish)
      PUBLISH="true"
      shift
      ;;
    --access-mode)
      [[ $# -ge 2 ]] || die "--access-mode requires public, password, or password_ask_info"
      PUBLICATION_ACCESS_MODE="$2"
      shift 2
      ;;
    --protected|--private)
      PUBLICATION_ACCESS_MODE="password"
      shift
      ;;
    --public)
      PUBLICATION_ACCESS_MODE="public"
      shift
      ;;
    --password)
      [[ $# -ge 2 ]] || die "--password requires a value"
      PUBLICATION_ACCESS_MODE="${PUBLICATION_ACCESS_MODE:-password}"
      PUBLICATION_PASSWORD="$2"
      shift 2
      ;;
    --generate-password)
      PUBLICATION_ACCESS_MODE="${PUBLICATION_ACCESS_MODE:-password}"
      PUBLICATION_REGENERATE_PASSWORD="true"
      shift
      ;;
    --unpublish)
      ACTION="unpublish_bucket"
      shift
      ;;
    --archive)
      ACTION="archive_bucket"
      shift
      ;;
    --unarchive)
      ACTION="unarchive_bucket"
      shift
      ;;
    --delete-bucket)
      ACTION="delete_bucket"
      shift
      ;;
    --expires-in-days)
      [[ $# -ge 2 ]] || die "--expires-in-days requires a value"
      EXPIRES_IN_DAYS="$2"
      PERMANENT_PUBLICATION="false"
      shift 2
      ;;
    --login)
      LOGIN="true"
      shift
      ;;
    --list-buckets)
      ACTION="list_buckets"
      shift
      ;;
    --list-versions)
      ACTION="list_versions"
      shift
      ;;
    --restore-version)
      [[ $# -ge 2 ]] || die "--restore-version requires a bucket version id"
      ACTION="restore_version"
      RESTORE_VERSION_ID="$2"
      shift 2
      ;;
    --restore-comment)
      [[ $# -ge 2 ]] || die "--restore-comment requires a value"
      RESTORE_COMMENT="$2"
      shift 2
      ;;
    --list-public-buckets)
      ACTION="list_public_buckets"
      shift
      ;;
    --account-status)
      ACTION="account_status"
      shift
      ;;
    --dashboard-link)
      ACTION="browser_login"
      BROWSER_LOGIN_PATH="/buckets"
      shift
      ;;
    --library-link)
      ACTION="browser_login"
      BROWSER_LOGIN_PATH="/library"
      shift
      ;;
    --access-link)
      ACTION="browser_login"
      BROWSER_LOGIN_PATH="/account/access"
      shift
      ;;
    --public-handle-link|--handle-link)
      ACTION="browser_login"
      BROWSER_LOGIN_PATH="/account/account"
      shift
      ;;
    --browser-login)
      [[ $# -ge 2 ]] || die "--browser-login requires an internal Revdoku path"
      ACTION="browser_login"
      BROWSER_LOGIN_PATH="$2"
      shift 2
      ;;
    --upload-mode)
      [[ $# -ge 2 ]] || die "--upload-mode requires a value"
      UPLOAD_MODE="$2"
      shift 2
      ;;
    --exchange-grant|--grant-token)
      [[ $# -ge 2 ]] || die "$1 requires a value"
      ACTION="exchange_grant"
      GRANT_TOKEN="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      PATH_TO_STORE="$1"
      shift
      ;;
  esac
done

[[ -n "$PATH_TO_STORE" ]] || PATH_TO_STORE="${1:-.}"
BASE_URL="${BASE_URL%/}"

need_cmd curl
need_cmd openssl
need_cmd base64
need_cmd find

if [[ -x "${SCRIPT_DIR}/jq" ]]; then
  JQ_BIN="${SCRIPT_DIR}/jq"
elif command -v jq >/dev/null 2>&1; then
  JQ_BIN="$(command -v jq)"
else
  die "requires jq"
fi

API_KEY_FROM_CREDENTIALS="false"
if [[ -z "$API_KEY" && -f "$CREDENTIALS_PATH" ]]; then
  API_KEY="$(tr -d '\r\n' < "$CREDENTIALS_PATH")"
  API_KEY_FROM_CREDENTIALS="true"
fi

if [[ -z "$BUCKET_ID" && "$API_KEY_FROM_CREDENTIALS" == "true" && -f "$DEFAULT_BUCKET_PATH" ]]; then
  BUCKET_ID="$(tr -d '\r\n' < "$DEFAULT_BUCKET_PATH")"
fi

if [[ -n "$METADATA_JSON" ]]; then
  METADATA_JSON="$(printf "%s" "$METADATA_JSON" | "$JQ_BIN" -c 'if type == "object" then . else error("metadata must be a JSON object") end')" || die "--metadata must be a JSON object"
else
  METADATA_JSON="{}"
fi

case "$PUBLICATION_ACCESS_MODE" in
  password-ask-info)
    PUBLICATION_ACCESS_MODE="password_ask_info"
    ;;
  ""|public|password|password_ask_info)
    ;;
  *)
    die "--access-mode must be public, password, or password_ask_info"
    ;;
esac

case "$PUBLICATION_REGENERATE_PASSWORD" in
  true|false)
    ;;
  *)
    die "REVDOKU_PUBLICATION_REGENERATE_PASSWORD must be true or false"
    ;;
esac

if [[ -n "$PUBLICATION_PASSWORD" || "$PUBLICATION_REGENERATE_PASSWORD" == "true" ]]; then
  case "${PUBLICATION_ACCESS_MODE:-password}" in
    password|password_ask_info)
      ;;
    *)
      die "--password or --generate-password requires --access-mode password or password_ask_info"
      ;;
  esac
  PUBLICATION_ACCESS_MODE="${PUBLICATION_ACCESS_MODE:-password}"
fi

if [[ -n "$PUBLICATION_PASSWORD" && "$PUBLICATION_REGENERATE_PASSWORD" == "true" ]]; then
  die "use either --password or --generate-password, not both"
fi

if [[ "$PUBLISH" != "true" && "$ACTION" == "store" && ( -n "$PUBLICATION_ACCESS_MODE" || -n "$PUBLICATION_PASSWORD" || "$PUBLICATION_REGENERATE_PASSWORD" == "true" ) ]]; then
  die "publication access options require --publish"
fi

api_url() {
  printf "%s%s" "$BASE_URL" "$1"
}

json_string() {
  "$JQ_BIN" -rn --arg value "$1" '$value'
}

agent_header_args() {
  printf "%s\0" \
    "-H" "User-Agent: Revdoku/${AGENT_VERSION} (${AGENT_CLIENT})" \
    "-H" "X-Revdoku-Agent: ${AGENT_NAME}" \
    "-H" "X-Revdoku-Agent-Client: ${AGENT_CLIENT}" \
    "-H" "X-Revdoku-Agent-Version: ${AGENT_VERSION}"
  [[ -n "$AGENT_RUN_ID" ]] && printf "%s\0" "-H" "X-Revdoku-Agent-Run-Id: ${AGENT_RUN_ID}"
  [[ -n "$AGENT_PROJECT" ]] && printf "%s\0" "-H" "X-Revdoku-Agent-Project: ${AGENT_PROJECT}"
  [[ -n "$AGENT_TASK" ]] && printf "%s\0" "-H" "X-Revdoku-Agent-Task: ${AGENT_TASK}"
}

http_json() {
  local method="$1"
  local path="$2"
  local payload="$3"
  local auth="${4:-true}"
  local body_file status message code retry_after attempt agent_args=()
  LAST_HTTP_STATUS=""
  LAST_ERROR_CODE=""
  LAST_ERROR_MESSAGE=""
  body_file="$(mktemp)"
  attempt=0

  while IFS= read -r -d '' value; do
    agent_args+=("$value")
  done < <(agent_header_args)

  local args=(-sS -o "$body_file" -w "%{http_code}" -X "$method" "$(api_url "$path")" "${agent_args[@]}" -H "Content-Type: application/json")
  if [[ "$auth" == "true" ]]; then
    args+=(-H "Authorization: Bearer $API_KEY")
  fi
  args+=(--data "$payload")

  while true; do
    : > "$body_file"
    status="$(curl "${args[@]}")" || {
      rm -f "$body_file"
      return 1
    }

    if [[ "$status" -ge 200 && "$status" -lt 300 ]]; then
      cat "$body_file"
      rm -f "$body_file"
      return 0
    fi

    message="$("$JQ_BIN" -r '.error.message // .message // empty' "$body_file" 2>/dev/null || true)"
    code="$("$JQ_BIN" -r '.error.code // empty' "$body_file" 2>/dev/null || true)"
    retry_after="$("$JQ_BIN" -r '.error.details.retry_after // empty' "$body_file" 2>/dev/null || true)"

    if [[ "$status" == "429" && "$attempt" -lt 20 ]]; then
      [[ "$retry_after" =~ ^[0-9]+$ && "$retry_after" -gt 0 ]] || retry_after=5
      attempt=$((attempt + 1))
      echo "Rate limited while calling $path; retrying in ${retry_after}s..." >&2
      sleep "$retry_after"
      continue
    fi

    rm -f "$body_file"
    LAST_HTTP_STATUS="$status"
    LAST_ERROR_CODE="$code"
    LAST_ERROR_MESSAGE="$message"
    [[ -n "$message" ]] || message="HTTP $status"
    [[ -n "$code" ]] && message="${message} (${code})"
    echo "error: $message" >&2
    if [[ "$auth" == "true" && ( "$status" == "401" || "$status" == "403" ) ]]; then
      echo "Run again with --login to reconnect and save a fresh Revdoku API key." >&2
    fi
    return 1
  done
}

prompt_read() {
  local prompt="$1"
  local value
  if [[ -r /dev/tty && -w /dev/tty ]]; then
    printf "%s" "$prompt" > /dev/tty
    IFS= read -r value < /dev/tty
  elif [[ -t 0 ]]; then
    printf "%s" "$prompt" >&2
    IFS= read -r value
  else
    die "REVDOKU_API_KEY is required. Run interactively with --login to create one."
  fi
  printf "%s" "$value"
}

request_agent_key() {
  local email code payload response key attempts
  attempts=0

  while true; do
    attempts=$((attempts + 1))
    email="$(prompt_read "Email: ")"
    [[ -n "$email" ]] || die "email is required"

    payload="$("$JQ_BIN" -nc --arg email "$email" '{email:$email}')"
    if http_json POST "/api/v1/agent_auth/request_code" "$payload" false >/dev/null; then
      break
    fi

    if [[ "$LAST_ERROR_CODE" != "SIGNUP_BLOCKED" ]]; then
      die "could not start email verification"
    fi
    [[ "$attempts" -lt 3 ]] || die "could not start email verification"
    echo "Please use a permanent email address. Disposable or blocked email domains are not accepted." >&2
  done

  echo "A Revdoku verification code was sent to $email." >&2

  code="$(prompt_read "Code: ")"
  [[ -n "$code" ]] || die "code is required"

  payload="$("$JQ_BIN" -nc --arg email "$email" --arg code "$code" '{email:$email, code:$code, label:"Revdoku bucket client"}')"
  response="$(http_json POST "/api/v1/agent_auth/verify_code" "$payload" false)"
  key="$("$JQ_BIN" -r '.data.api_key // empty' <<<"$response")"
  [[ -n "$key" ]] || die "verification did not return an API key"

  mkdir -p "$(dirname "$CREDENTIALS_PATH")"
  umask 077
  printf "%s\n" "$key" > "$CREDENTIALS_PATH"
  echo "Saved Revdoku API key to $CREDENTIALS_PATH" >&2
  echo "This is a one-time setup. Future runs will reuse the saved key automatically." >&2
  API_KEY="$key"
}

if [[ "$ACTION" != "exchange_grant" && ( "$LOGIN" == "true" || -z "$API_KEY" ) ]]; then
  request_agent_key
fi

[[ "$ACTION" == "exchange_grant" || -n "$API_KEY" ]] || die "REVDOKU_API_KEY is required"
case "$UPLOAD_MODE" in
  auto|direct|multipart) ;;
  *) die "--upload-mode must be auto, direct, or multipart" ;;
esac
case "$PUBLISH" in
  true|false) ;;
  *) die "REVDOKU_PUBLISH must be true or false" ;;
esac
case "$PERMANENT_PUBLICATION" in
  true|false) ;;
  *) die "REVDOKU_PERMANENT_PUBLICATION must be true or false" ;;
esac
if [[ "$PERMANENT_PUBLICATION" == "false" && -z "$EXPIRES_IN_DAYS" ]]; then
  EXPIRES_IN_DAYS="7"
fi
if [[ -n "$EXPIRES_IN_DAYS" ]]; then
  [[ "$EXPIRES_IN_DAYS" =~ ^[0-9]+$ && "$EXPIRES_IN_DAYS" -gt 0 ]] || die "--expires-in-days must be a positive number of days"
fi

list_buckets() {
  local active_response archived_response
  active_response="$(http_json GET "/api/v1/buckets" "{}")"
  archived_response="$(http_json GET "/api/v1/buckets?archived=true" "{}")"
  "$JQ_BIN" -nc \
    --argjson active "$active_response" \
    --argjson archived "$archived_response" \
    '
      ($active.data.buckets // []) as $active_buckets
      | ($archived.data.buckets // []) as $archived_buckets
      | ($active_buckets + $archived_buckets | unique_by(.id)) as $buckets
      | $active + {
          data: ($active.data + {
            buckets: $buckets,
            active_buckets_count: ($active_buckets | length),
            archived_buckets_count: ($archived_buckets | length),
            includes_archived: true
          })
        }
    '
}

list_versions() {
  [[ -n "$BUCKET_ID" ]] || die "--list-versions requires --bucket-id"
  http_json GET "/api/v1/buckets/${BUCKET_ID}/versions" "{}"
}

restore_version() {
  local payload
  [[ -n "$BUCKET_ID" ]] || die "--restore-version requires --bucket-id"
  [[ -n "$RESTORE_VERSION_ID" ]] || die "--restore-version requires a bucket version id"
  payload="$("$JQ_BIN" -nc \
    --arg version_id "$RESTORE_VERSION_ID" \
    --arg comment "$RESTORE_COMMENT" \
    '{version_id:$version_id} + (if $comment != "" then {comment:$comment} else {} end)')"
  http_json POST "/api/v1/buckets/${BUCKET_ID}/versions/restore" "$payload"
}

unpublish_bucket() {
  [[ -n "$BUCKET_ID" ]] || die "--unpublish requires --bucket-id"
  http_json DELETE "/api/v1/buckets/${BUCKET_ID}/publication" "{}" | "$JQ_BIN" -c '
    .data.publication as $publication
    | {
        success: (.success // true),
        data: {
          publication: $publication,
          bucket_id: $publication.bucket_id,
          public_slug: $publication.public_slug,
          public_url: $publication.public_url,
          status: $publication.status,
          revoked_at: $publication.revoked_at,
          guidance: "The public site is unpublished. Republish this same bucket to restore the same URL."
        }
      }'
}

archive_bucket() {
  [[ -n "$BUCKET_ID" ]] || die "--archive requires --bucket-id"
  http_json POST "/api/v1/buckets/${BUCKET_ID}/archive" "{}"
}

unarchive_bucket() {
  [[ -n "$BUCKET_ID" ]] || die "--unarchive requires --bucket-id"
  http_json POST "/api/v1/buckets/${BUCKET_ID}/unarchive" "{}"
}

delete_bucket() {
  local bucket_response allowed required_action confirmation payload
  [[ -n "$BUCKET_ID" ]] || die "--delete-bucket requires --bucket-id"
  bucket_response="$(http_json GET "/api/v1/buckets/${BUCKET_ID}" "{}")"
  allowed="$("$JQ_BIN" -r '.data.bucket.delete.allowed // false' <<<"$bucket_response")"
  required_action="$("$JQ_BIN" -r '.data.bucket.delete.required_action // empty' <<<"$bucket_response")"
  confirmation="$("$JQ_BIN" -r '.data.bucket.delete.confirmation // empty' <<<"$bucket_response")"

  if [[ "$allowed" != "true" || -z "$confirmation" ]]; then
    case "$required_action" in
      unpublish_first)
        die "bucket must be unpublished before permanent delete; run with --unpublish first after confirmation"
        ;;
      archive_first)
        die "bucket must be archived before permanent delete; run with --archive first after confirmation"
        ;;
      *)
        die "bucket cannot be permanently deleted with this connection"
        ;;
    esac
  fi

  payload="$("$JQ_BIN" -nc --arg confirmation "$confirmation" '{confirmation:$confirmation}')"
  http_json DELETE "/api/v1/buckets/${BUCKET_ID}" "$payload"
}

account_status() {
  http_json GET "/api/v1/account/credits" "{}" | "$JQ_BIN" -c '
    .data.credits as $credits
    | ($credits.account_limits // {}) as $limits
    | {
        success: (.success // true),
        data: {
          account: {
            id: $credits.account_id,
            name: $credits.account_name
          },
          plan: ($credits.plan // {}),
          storage: {
            used_bytes: $limits.used_storage_bytes,
            used_human: $limits.used_storage_human,
            available_bytes: $limits.available_storage_bytes,
            available_human: $limits.available_storage_human,
            max_mb: $limits.max_storage_mb,
            max_human: $limits.max_storage_human,
            max_file_size_mb: $limits.max_file_size_mb,
            max_file_size_human: $limits.max_file_size_human
          },
          connections: {
            max: $limits.max_account_connections,
            active_api_keys_count: $limits.active_api_keys_count,
            api_rate_limit_requests_per_minute: $limits.api_rate_limit_requests_per_minute
          },
          credits: {
            balance: $credits.balance,
            subscription: $credits.subscription,
            purchased: $credits.purchased,
            total: $credits.total,
            purchased_expires_at: $credits.purchased_expires_at,
            next_refill_at: $credits.next_refill_at,
            one_time_credits_purchasable: $credits.one_time_credits_purchasable
          }
        }
      }'
}

exchange_grant() {
  local payload response key bucket_access default_bucket_id
  [[ -n "$GRANT_TOKEN" ]] || die "grant token is required"
  payload="$("$JQ_BIN" -nc --arg grant_token "$GRANT_TOKEN" '{grant_token:$grant_token, label:"Revdoku bucket client"}')"
  response="$(http_json POST "/api/v1/agent_auth/exchange_grant" "$payload" false)"
  key="$("$JQ_BIN" -r '.data.api_key // empty' <<<"$response")"
  [[ -n "$key" ]] || die "grant exchange did not return an API key"
  bucket_access="$("$JQ_BIN" -r '.data.bucket_access // "all"' <<<"$response")"
  default_bucket_id="$("$JQ_BIN" -r 'if (.data.bucket_access == "selected") then ((.data.bucket_ids // []) | map(select(startswith("bkt_"))) | .[0] // empty) else empty end' <<<"$response")"

  mkdir -p "$(dirname "$CREDENTIALS_PATH")"
  umask 077
  printf "%s\n" "$key" > "$CREDENTIALS_PATH"
  echo "Saved Revdoku API key to $CREDENTIALS_PATH" >&2
  if [[ "$bucket_access" == "selected" && -n "$default_bucket_id" ]]; then
    printf "%s\n" "$default_bucket_id" > "$DEFAULT_BUCKET_PATH"
    echo "Saved default Revdoku bucket to $DEFAULT_BUCKET_PATH" >&2
  else
    rm -f "$DEFAULT_BUCKET_PATH"
  fi
  echo "This is a one-time setup. Future runs will reuse the saved key automatically." >&2
  printf "%s\n" "$("$JQ_BIN" -c '{success:(.success // true), data:{account_id:.data.account_id, account_name:.data.account_name, bucket_access:.data.bucket_access, bucket_ids:(.data.bucket_ids // []), bucket_permissions:(.data.bucket_permissions // {}), account_connection_limits:.data.account_connection_limits, manage_access:.data.manage_access, guidance:.data.guidance, link_hint:(if ((.data.manage_access.url // "") != "") then "If opening links from a terminal, Cmd-click on macOS or Ctrl-click on Windows/Linux when supported." else null end), access_hint:(if ((.data.manage_access.url // "") == "") then "No browser login link was issued. Open Revdoku through the normal browser sign-in flow to manage this agent." else null end)}}' <<<"$response")"
}

list_public_buckets() {
  http_json GET "/api/v1/publications" "{}" | "$JQ_BIN" -c '
    .data.publications
    | map(select(.kind == "bucket_bundle" and (.public_url // "") != "" and ((.active == true) or ((has("active") | not) and .status == "published"))))
    | group_by(.bucket_id)
    | map({
        bucket_id: .[0].bucket_id,
        publications: map({
          id,
          public_slug,
          title,
          url: .public_url,
          status,
          permanent: (.permanent // false),
          expires_at,
          created_at,
          hits: (.analytics.hits_all_time // 0)
        })
      })
    | {data:{public_buckets:., link_hint:"If opening links from a terminal, Cmd-click on macOS or Ctrl-click on Windows/Linux when supported."}}'
}

print_terminal_link_hint() {
  if [[ -t 2 ]]; then
    echo "Tip: Cmd-click the link on macOS, or Ctrl-click it on Windows/Linux, if your terminal supports clickable links." >&2
  fi
}

print_public_profile_listing_hint_from_response() {
  local response="$1"
  local profile_url
  profile_url="$("$JQ_BIN" -r '.data.publication.account_public_profile_url // .data.publication.public_profile.url // empty' <<<"$response" 2>/dev/null || true)"
  if [[ -n "$profile_url" ]]; then
    echo "All your public sites are listed at $profile_url" >&2
  fi
}

print_publication_access_hint_from_response() {
  local response="$1"
  local access_mode password url
  access_mode="$("$JQ_BIN" -r '.data.publication.access_mode // empty' <<<"$response" 2>/dev/null || true)"
  [[ "$access_mode" == "password" || "$access_mode" == "password_ask_info" ]] || return 0

  url="$("$JQ_BIN" -r '.data.publication.public_url // empty' <<<"$response" 2>/dev/null || true)"
  password="$("$JQ_BIN" -r '.data.publication.access_password // .data.publication.generated_password // empty' <<<"$response" 2>/dev/null || true)"
  if [[ -n "$password" ]]; then
    echo "Protected website password: $password" >&2
    [[ -n "$url" ]] && echo "Open $url and enter the password. The password is not included in the URL." >&2
  else
    echo "Protected website password is stored, but this API key cannot view it. Use an owner publish key to retrieve or regenerate it." >&2
  fi
}

browser_login_link() {
  local payload response url expires redirect_path
  payload="$("$JQ_BIN" -nc --arg redirect_path "$BROWSER_LOGIN_PATH" '{redirect_path:$redirect_path}')"
  response="$(http_json POST "/api/v1/agent_auth/browser_login_link" "$payload")"
  url="$("$JQ_BIN" -r '.data.url // empty' <<<"$response")"
  expires="$("$JQ_BIN" -r '.data.expires_in_seconds // empty' <<<"$response")"
  redirect_path="$("$JQ_BIN" -r '.data.redirect_path // empty' <<<"$response")"
  [[ -n "$url" ]] || die "browser login response did not include url"
  echo "Open Revdoku: $url" >&2
  [[ -n "$redirect_path" ]] && echo "Destination: $redirect_path" >&2
  [[ -n "$expires" ]] && echo "This link is single-use and expires in ${expires} seconds." >&2
  print_terminal_link_hint
  printf "%s\n" "$url"
}

case "$ACTION" in
  list_buckets)
    list_buckets
    exit 0
    ;;
  list_versions)
    list_versions
    exit 0
    ;;
  restore_version)
    restore_version
    exit 0
    ;;
  unpublish_bucket)
    unpublish_bucket
    exit 0
    ;;
  archive_bucket)
    archive_bucket
    exit 0
    ;;
  unarchive_bucket)
    unarchive_bucket
    exit 0
    ;;
  delete_bucket)
    delete_bucket
    exit 0
    ;;
  list_public_buckets)
    list_public_buckets
    exit 0
    ;;
  account_status)
    account_status
    exit 0
    ;;
  browser_login)
    browser_login_link
    exit 0
    ;;
  exchange_grant)
    exchange_grant
    exit 0
    ;;
esac

[[ -e "$PATH_TO_STORE" ]] || die "$PATH_TO_STORE does not exist"

abs_path() {
  local path="$1"
  if [[ -d "$path" ]]; then
    (cd "$path" && pwd)
  else
    local dir base
    dir="$(dirname "$path")"
    base="$(basename "$path")"
    printf "%s/%s" "$(cd "$dir" && pwd)" "$base"
  fi
}

ROOT_PATH="$(abs_path "$PATH_TO_STORE")"

default_title() {
  basename "$ROOT_PATH"
}

effective_metadata_json() {
  if [[ -d "$ROOT_PATH" ]]; then
    "$JQ_BIN" -nc \
      --arg root "$(basename "$ROOT_PATH")" \
      --argjson metadata "$METADATA_JSON" \
      '$metadata | if has("publication_root_directory") then . else . + {publication_root_directory: $root} end'
  else
    printf "%s" "$METADATA_JSON"
  fi
}

default_entrypoint() {
  printf "index.html"
}

publication_access_json() {
  "$JQ_BIN" -nc \
    --arg access_mode "$PUBLICATION_ACCESS_MODE" \
    --arg password "$PUBLICATION_PASSWORD" \
    --arg regenerate_password "$PUBLICATION_REGENERATE_PASSWORD" \
    '{}
    + (if $access_mode != "" then {access_mode: $access_mode} else {} end)
    + (if $password != "" then {password: $password} else {} end)
    + (if $regenerate_password == "true" then {regenerate_password: true} else {} end)'
}

has_index_file() {
  if [[ -f "$ROOT_PATH" ]]; then
    [[ "$(basename "$ROOT_PATH")" == "index.html" ]]
  else
    [[ -f "$ROOT_PATH/index.html" ]]
  fi
}

content_type_for() {
  local file="$1"
  local lower="${file##*.}"
  lower="$(printf "%s" "$lower" | tr '[:upper:]' '[:lower:]')"
  case "$lower" in
    html|htm) echo "text/html" ;;
    css|csss|scss|sass|less|styl|stylus) echo "text/css" ;;
    js|mjs|cjs) echo "text/javascript" ;;
    map) echo "application/json" ;;
    webmanifest) echo "application/manifest+json" ;;
    json) echo "application/json" ;;
    txt) echo "text/plain" ;;
    md) echo "text/markdown" ;;
    png) echo "image/png" ;;
    apng) echo "image/apng" ;;
    jpg|jpe|jpeg|jfif|pjp|pjpeg) echo "image/jpeg" ;;
    webp) echo "image/webp" ;;
    gif) echo "image/gif" ;;
    avif) echo "image/avif" ;;
    bmp) echo "image/bmp" ;;
    ico|cur) echo "image/x-icon" ;;
    heic|heics) echo "image/heic" ;;
    heif|heifs) echo "image/heif" ;;
    jp2) echo "image/jp2" ;;
    svg) echo "image/svg+xml" ;;
    woff) echo "font/woff" ;;
    woff2) echo "font/woff2" ;;
    ttf) echo "font/ttf" ;;
    otf) echo "font/otf" ;;
    wasm) echo "application/wasm" ;;
    pdf) echo "application/pdf" ;;
    xml) echo "application/xml" ;;
    rss) echo "application/rss+xml" ;;
    atom) echo "application/atom+xml" ;;
    mp4) echo "video/mp4" ;;
    mov) echo "video/quicktime" ;;
    webm) echo "video/webm" ;;
    m4v) echo "video/x-m4v" ;;
    ogv) echo "video/ogg" ;;
    avi) echo "video/x-msvideo" ;;
    mkv) echo "video/x-matroska" ;;
    mpg|mpeg) echo "video/mpeg" ;;
    ts) echo "video/mp2t" ;;
    m3u8) echo "application/vnd.apple.mpegurl" ;;
    mp3) echo "audio/mpeg" ;;
    ogg|oga) echo "audio/ogg" ;;
    wav) echo "audio/wav" ;;
    m4a) echo "audio/mp4" ;;
    aac) echo "audio/aac" ;;
    flac) echo "audio/flac" ;;
    opus) echo "audio/opus" ;;
    *) echo "application/octet-stream" ;;
  esac
}

file_size() {
  wc -c < "$1" | tr -d '[:space:]'
}

md5_base64() {
  openssl dgst -md5 -binary "$1" | base64 | tr -d '\r\n'
}

sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    openssl dgst -sha256 "$1" | awk '{print $2}'
  fi
}

relative_path_for() {
  local file="$1"
  if [[ -f "$ROOT_PATH" ]]; then
    basename "$file"
  else
    printf "%s/%s" "$(basename "$ROOT_PATH")" "${file#"$ROOT_PATH"/}"
  fi
}

local_file_for_relative_path() {
  local rel="$1"
  local root_name
  if [[ -f "$ROOT_PATH" ]]; then
    printf "%s" "$ROOT_PATH"
    return
  fi

  root_name="$(basename "$ROOT_PATH")"
  if [[ "$rel" == "$root_name/"* ]]; then
    printf "%s/%s" "$ROOT_PATH" "${rel#"$root_name"/}"
  else
    printf "%s/%s" "$ROOT_PATH" "$rel"
  fi
}

create_bucket() {
  local title payload response id
  title="$TITLE"
  [[ -n "$title" ]] || title="$(default_title)"
  payload="$(bucket_payload "$title")"
  response="$(http_json POST "/api/v1/buckets" "$payload")" || die "bucket create failed"
  id="$("$JQ_BIN" -r '.data.bucket.id // empty' <<<"$response")"
  [[ -n "$id" ]] || die "bucket create response did not include id"
  printf "%s" "$id"
}

tag_paths_json() {
  if [[ "${#TAG_PATHS[@]}" -eq 0 ]]; then
    printf "[]"
  else
    "$JQ_BIN" -nc '$ARGS.positional' --args "${TAG_PATHS[@]}"
  fi
}

bucket_payload() {
  local title="$1"
  local tag_paths metadata
  tag_paths="$(tag_paths_json)"
  metadata="$(effective_metadata_json)"
  "$JQ_BIN" -nc \
    --arg title "$title" \
    --arg description "$DESCRIPTION" \
    --argjson metadata "$metadata" \
    --argjson tag_paths "$tag_paths" \
    '{
      bucket: (
        {title: $title, metadata: $metadata}
        + (if $description != "" then {description: $description} else {} end)
        + (if ($tag_paths | length) > 0 then {tag_paths: $tag_paths} else {} end)
      )
    }'
}

bucket_update_payload() {
  local tag_paths
  tag_paths="$(tag_paths_json)"
  "$JQ_BIN" -nc \
    --arg title "$TITLE" \
    --arg description "$DESCRIPTION" \
    --argjson metadata "$METADATA_JSON" \
    --argjson tag_paths "$tag_paths" \
    '{
      bucket: (
        {}
        + (if $title != "" then {title: $title} else {} end)
        + (if $description != "" then {description: $description} else {} end)
        + (if ($metadata | length) > 0 then {metadata: $metadata} else {} end)
        + (if ($tag_paths | length) > 0 then {tag_paths: $tag_paths} else {} end)
      )
    }'
}

bucket_update_needed() {
  [[ "$METADATA_JSON" != "{}" || -n "$DESCRIPTION" || "${#TAG_PATHS[@]}" -gt 0 ]]
}

put_direct_upload() {
  local upload_json="$1"
  local file="$2"
  local url header_args=()
  url="$("$JQ_BIN" -r '.url // empty' <<<"$upload_json")"
  [[ -n "$url" ]] || return 1

  while IFS=$'\t' read -r key value; do
    [[ -n "$key" ]] || continue
    header_args+=(-H "${key}: ${value}")
  done < <("$JQ_BIN" -r '.headers // {} | to_entries[] | [.key, .value] | @tsv' <<<"$upload_json")

  curl -fsS -X PUT "${header_args[@]}" --data-binary "@${file}" "$url" >/dev/null
}

put_publish_session_upload() {
  local session_id="$1"
  local rel="$2"
  local upload_json="$3"
  local file="$4"
  local refresh_response refreshed_upload

  if put_direct_upload "$upload_json" "$file"; then
    return 0
  fi

  echo "Upload URL failed for $rel; refreshing upload URL and retrying." >&2
  refresh_response="$(http_json POST "/api/v1/publish_sessions/${session_id}/uploads/refresh" "{}")" || return 1
  refreshed_upload="$("$JQ_BIN" -c --arg path "$rel" '.data.publish_session.uploads[]? | select(.path == $path) | .upload' <<<"$refresh_response" | head -n 1)"
  if [[ -z "$refreshed_upload" || "$refreshed_upload" == "null" ]]; then
    echo "Upload for $rel was already accepted by Revdoku." >&2
    return 0
  fi

  put_direct_upload "$refreshed_upload" "$file"
}

publish_session_retryable_error() {
  case "${LAST_ERROR_CODE:-}" in
    PUBLISH_SESSION_STALE|PUBLISH_SESSION_EXPIRED|PUBLISH_SESSION_NOT_PENDING)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

publication_limit_error() {
  [[ "${LAST_ERROR_CODE:-}" == "PUBLICATION_LIMIT_REACHED" ]]
}

private_publication_limit_error() {
  [[ "${LAST_ERROR_CODE:-}" == "PRIVATE_PUBLICATION_LIMIT_REACHED" ]]
}

publish_session_fallback_allowed() {
  case "${LAST_HTTP_STATUS:-}" in
    401|403)
      return 1
      ;;
  esac

  case "${LAST_ERROR_CODE:-}" in
    PUBLICATION_LIMIT_REACHED|PRIVATE_PUBLICATION_LIMIT_REACHED|PUBLIC_STORAGE_NOT_CONFIGURED|PRIVATE_PUBLICATION_STORAGE_NOT_CONFIGURED|UNAUTHORIZED|FORBIDDEN|BUCKET_ACCESS_DENIED|BUCKET_PERMISSION_DENIED|BUCKET_LIMIT_REACHED|STORAGE_QUOTA_EXCEEDED)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

print_publication_limit_guidance() {
  echo "Live public site limit reached for this account." >&2
  if [[ -n "$LAST_PUBLISH_SESSION_BUCKET_ID" ]]; then
    echo "Private bucket storage is still available: $LAST_PUBLISH_SESSION_BUCKET_ID" >&2
  fi
  echo "To update an existing public site, rerun with --bucket-id for that public bucket; republishing keeps the same URL and does not use another live-site slot." >&2
  echo "To publish a new site, list current public buckets with --list-public-buckets, then ask before unpublishing one with --unpublish, or open /pricing to upgrade." >&2
}

print_private_publication_limit_guidance() {
  echo "Protected website limit reached for this account." >&2
  if [[ -n "$LAST_PUBLISH_SESSION_BUCKET_ID" ]]; then
    echo "Private bucket storage is still available: $LAST_PUBLISH_SESSION_BUCKET_ID" >&2
  fi
  echo "Protected websites require available Pro protected-site capacity. Publish publicly, unpublish another protected website, or update the plan." >&2
}

upload_file_direct() {
  local bucket_id="$1"
  local file="$2"
  local rel filename content_type size checksum sha256 payload response direct_upload signed_id
  rel="$(relative_path_for "$file")"
  filename="$(basename "$file")"
  content_type="$(content_type_for "$file")"
  size="$(file_size "$file")"
  checksum="$(md5_base64 "$file")"
  sha256="$(sha256_file "$file")"

  payload="$("$JQ_BIN" -nc \
    --arg bucket_id "$bucket_id" \
    --arg path "$rel" \
    --arg filename "$filename" \
    --argjson byte_size "$size" \
    --arg checksum "$checksum" \
    --arg content_type "$content_type" \
    --arg sha256 "$sha256" \
    '{bucket_id:$bucket_id, path:$path, blob:{filename:$filename, byte_size:$byte_size, checksum:$checksum, content_type:$content_type, sha256:$sha256, purpose:"bucket_file"}}')"
  response="$(http_json POST "/api/v1/direct_uploads" "$payload")" || return 1
  direct_upload="$("$JQ_BIN" -c '.data.direct_upload // empty' <<<"$response")"
  signed_id="$("$JQ_BIN" -r '.data.signed_id // empty' <<<"$response")"
  [[ -n "$direct_upload" && -n "$signed_id" ]] || return 1

  put_direct_upload "$direct_upload" "$file" || return 1

  payload="$("$JQ_BIN" -nc --arg signed_blob_id "$signed_id" --arg path "$rel" --arg name "$filename" \
    '{signed_blob_id:$signed_blob_id, path:$path, name:$name}')"
  http_json POST "/api/v1/buckets/${bucket_id}/files" "$payload" >/dev/null
}

upload_file_multipart() {
  local bucket_id="$1"
  local file="$2"
  local rel filename content_type body_file status message agent_args=()
  rel="$(relative_path_for "$file")"
  filename="$(basename "$file")"
  content_type="$(content_type_for "$file")"
  body_file="$(mktemp)"
  while IFS= read -r -d '' value; do
    agent_args+=("$value")
  done < <(agent_header_args)
  status="$(curl -sS -o "$body_file" -w "%{http_code}" \
    -X POST "$(api_url "/api/v1/buckets/${bucket_id}/files")" \
    "${agent_args[@]}" \
    -H "Authorization: Bearer $API_KEY" \
    -F "path=${rel}" \
    -F "name=${filename}" \
    -F "file=@${file};filename=${filename};type=${content_type}")" || {
      rm -f "$body_file"
      return 1
  }
  if [[ "$status" -lt 200 || "$status" -ge 300 ]]; then
    message="$("$JQ_BIN" -r '.error.message // .message // empty' "$body_file" 2>/dev/null || true)"
    rm -f "$body_file"
    [[ -n "$message" ]] || message="HTTP $status"
    echo "error: upload failed for $rel: $message" >&2
    return 1
  fi
  rm -f "$body_file"
}

upload_file() {
  local bucket_id="$1"
  local file="$2"
  local rel
  rel="$(relative_path_for "$file")"
  echo "Uploading $rel" >&2

  if [[ "$UPLOAD_MODE" != "multipart" ]]; then
    if upload_file_direct "$bucket_id" "$file"; then
      return 0
    fi
    if [[ "$UPLOAD_MODE" == "direct" ]]; then
      echo "Direct upload failed for $rel; retrying with multipart upload." >&2
    else
      echo "Direct upload failed for $rel; retrying with compatibility upload." >&2
    fi
  fi

  upload_file_multipart "$bucket_id" "$file"
}

publish_bucket() {
  local bucket_id="$1"
  local payload response response_file url entrypoint metadata access
  entrypoint="$(default_entrypoint)"
  metadata="$(effective_metadata_json)"
  access="$(publication_access_json)"
  if [[ "$PERMANENT_PUBLICATION" == "true" ]]; then
    payload="$("$JQ_BIN" -nc --arg entrypoint "$entrypoint" --argjson metadata "$metadata" --argjson access "$access" '{permanent:true, entrypoint:$entrypoint, metadata:$metadata} + $access')"
  else
    payload="$("$JQ_BIN" -nc --arg entrypoint "$entrypoint" --argjson expires_in_days "$EXPIRES_IN_DAYS" --argjson metadata "$metadata" --argjson access "$access" '{expires_in_days:$expires_in_days, entrypoint:$entrypoint, metadata:$metadata} + $access')"
  fi
  response_file="$(mktemp)"
  if ! http_json POST "/api/v1/buckets/${bucket_id}/publication" "$payload" > "$response_file"; then
    rm -f "$response_file"
    if [[ "${LAST_ERROR_CODE:-}" == "PUBLIC_STORAGE_NOT_CONFIGURED" ]]; then
      echo "Public publishing is not configured for this Revdoku deployment." >&2
      echo "Private bucket storage is still available: $bucket_id" >&2
    elif [[ "${LAST_ERROR_CODE:-}" == "PRIVATE_PUBLICATION_STORAGE_NOT_CONFIGURED" ]]; then
      echo "Protected website publishing is not configured for this Revdoku deployment." >&2
      echo "Private bucket storage is still available: $bucket_id" >&2
    elif publication_limit_error; then
      LAST_PUBLISH_SESSION_BUCKET_ID="$bucket_id"
      print_publication_limit_guidance
    elif private_publication_limit_error; then
      LAST_PUBLISH_SESSION_BUCKET_ID="$bucket_id"
      print_private_publication_limit_guidance
    fi
    die "bucket publish failed"
  fi
  response="$(cat "$response_file")"
  rm -f "$response_file"
  url="$("$JQ_BIN" -r '.data.publication.public_url // empty' <<<"$response")"
  [[ -n "$url" ]] || die "publish response did not include url"
  print_public_profile_listing_hint_from_response "$response"
  print_publication_access_hint_from_response "$response"
  printf "%s\n" "$url"
}

publish_session_manifest_json() {
  local file_list="$1"
  local manifest_lines rel filename content_type size checksum sha256
  manifest_lines="$(mktemp)"
  while IFS= read -r -d '' file; do
    rel="$(relative_path_for "$file")"
    filename="$(basename "$file")"
    content_type="$(content_type_for "$file")"
    size="$(file_size "$file")"
    checksum="$(md5_base64 "$file")"
    sha256="$(sha256_file "$file")"
    "$JQ_BIN" -nc \
      --arg path "$rel" \
      --argjson byte_size "$size" \
      --arg content_type "$content_type" \
      --arg checksum "$checksum" \
      --arg sha256 "$sha256" \
      '{path:$path, byte_size:$byte_size, content_type:$content_type, checksum:$checksum, sha256:$sha256}' >> "$manifest_lines"
  done < "$file_list"
  "$JQ_BIN" -sc '.' "$manifest_lines"
  rm -f "$manifest_lines"
}

publish_session_payload() {
  local manifest_json="$1"
  local title tag_paths expires_in_days entrypoint metadata access
  title="$TITLE"
  [[ -n "$title" ]] || title="$(default_title)"
  tag_paths="$(tag_paths_json)"
  expires_in_days="${EXPIRES_IN_DAYS:-7}"
  entrypoint="$(default_entrypoint)"
  metadata="$(effective_metadata_json)"
  access="$(publication_access_json)"
  "$JQ_BIN" -nc \
    --arg title "$title" \
    --arg description "$DESCRIPTION" \
    --arg bucket_id "$BUCKET_ID" \
    --arg permanent "$PERMANENT_PUBLICATION" \
    --arg entrypoint "$entrypoint" \
    --argjson expires_in_days "$expires_in_days" \
    --argjson metadata "$metadata" \
    --argjson access "$access" \
    --argjson tag_paths "$tag_paths" \
    --argjson files "$manifest_json" \
    '{
      title: $title,
      bucket_title: $title,
      entrypoint: $entrypoint,
      metadata: $metadata,
      files: $files
    }
    + (if $bucket_id != "" then {bucket_id: $bucket_id} else {} end)
    + (if $description != "" then {bucket_description: $description} else {} end)
    + (if ($tag_paths | length) > 0 then {bucket_tag_paths: $tag_paths} else {} end)
    + (if $permanent == "true" then {permanent: true} else {expires_in_days: $expires_in_days} end)
    + $access'
}

publish_session_file_for_path() {
  local rel="$1"
  local_file_for_relative_path "$rel"
}

publish_bucket_session_attempt() {
  local file_list="$1"
  local manifest_json payload response response_file session_id bucket_id upload_line rel upload_json file finalize_url final_response final_response_file url
  manifest_json="$(publish_session_manifest_json "$file_list")"
  payload="$(publish_session_payload "$manifest_json")"
  response_file="$(mktemp)"
  if ! http_json POST "/api/v1/publish_sessions" "$payload" > "$response_file"; then
    rm -f "$response_file"
    return 1
  fi
  response="$(cat "$response_file")"
  rm -f "$response_file"

  session_id="$("$JQ_BIN" -r '.data.publish_session.id // empty' <<<"$response")"
  bucket_id="$("$JQ_BIN" -r '.data.publish_session.bucket_id // empty' <<<"$response")"
  LAST_PUBLISH_SESSION_BUCKET_ID="$bucket_id"
  [[ -n "$session_id" ]] || {
    die "publish session response did not include id"
  }
  [[ -n "$bucket_id" ]] && echo "Bucket: $bucket_id" >&2
  echo "Publish session: $session_id" >&2

  while IFS= read -r upload_line; do
    [[ -n "$upload_line" ]] || continue
    rel="$("$JQ_BIN" -r '.path' <<<"$upload_line")"
    upload_json="$("$JQ_BIN" -c '.upload' <<<"$upload_line")"
    file="$(publish_session_file_for_path "$rel")"
    [[ -f "$file" ]] || {
      die "publish session asked for unknown upload path: $rel"
    }
    echo "Uploading $rel" >&2
    if ! put_publish_session_upload "$session_id" "$rel" "$upload_json" "$file"; then
      return 1
    fi
  done < <("$JQ_BIN" -c '.data.publish_session.uploads[]?' <<<"$response")

  finalize_url="$("$JQ_BIN" -r '.data.finalize.url // empty' <<<"$response")"
  [[ -n "$finalize_url" ]] || {
    die "publish session response did not include finalize URL"
  }
  final_response_file="$(mktemp)"
  if ! http_json POST "$finalize_url" "{}" > "$final_response_file"; then
    rm -f "$final_response_file"
    return 1
  fi
  final_response="$(cat "$final_response_file")"
  rm -f "$final_response_file"

  url="$("$JQ_BIN" -r '.data.publication.public_url // empty' <<<"$final_response")"
  [[ -n "$url" ]] || die "publish response did not include url"
  print_public_profile_listing_hint_from_response "$final_response"
  print_publication_access_hint_from_response "$final_response"
  printf "%s\n" "$url"
}

publish_bucket_session() {
  local file_list publish_url publish_url_file
  file_list="$(mktemp)"
  if ! collect_files > "$file_list"; then
    rm -f "$file_list"
    return 1
  fi
  if [[ ! -s "$file_list" ]]; then
    rm -f "$file_list"
    die "no files found to publish after safety exclusions"
  fi

  publish_url_file="$(mktemp)"
  if publish_bucket_session_attempt "$file_list" > "$publish_url_file"; then
    publish_url="$(cat "$publish_url_file")"
    rm -f "$publish_url_file"
    rm -f "$file_list"
    printf "%s\n" "$publish_url"
    return 0
  fi

  if publish_session_retryable_error; then
    echo "Publish session became stale or expired; starting a fresh publish session." >&2
    if publish_bucket_session_attempt "$file_list" > "$publish_url_file"; then
      publish_url="$(cat "$publish_url_file")"
      rm -f "$publish_url_file"
      rm -f "$file_list"
      printf "%s\n" "$publish_url"
      return 0
    fi
  fi

  rm -f "$publish_url_file"
  rm -f "$file_list"
  return 1
}

bucket_id_for_storage() {
  if [[ -n "$BUCKET_ID" ]]; then
    if bucket_update_needed; then
      local payload
      payload="$(bucket_update_payload)"
      http_json PATCH "/api/v1/buckets/${BUCKET_ID}" "$payload" >/dev/null
    fi
    printf "%s" "$BUCKET_ID"
  else
    create_bucket
  fi
}

store_bucket() {
  local bucket_id bucket_id_file file file_list
  file_list="$(mktemp)"
  if ! collect_files > "$file_list"; then
    rm -f "$file_list"
    return 1
  fi
  if [[ ! -s "$file_list" ]]; then
    rm -f "$file_list"
    die "no files found to store after safety exclusions"
  fi

  bucket_id_file="$(mktemp)"
  if ! bucket_id_for_storage > "$bucket_id_file"; then
    rm -f "$bucket_id_file" "$file_list"
    return 1
  fi
  bucket_id="$(cat "$bucket_id_file")"
  rm -f "$bucket_id_file"
  [[ -n "$bucket_id" ]] || {
    rm -f "$file_list"
    die "bucket id is required before uploading files"
  }
  echo "Bucket: $bucket_id" >&2
  while IFS= read -r -d '' file; do
    upload_file "$bucket_id" "$file"
  done < "$file_list"
  rm -f "$file_list"
  printf "%s" "$bucket_id"
}

verify_published_url() {
  local url="$1"
  curl -fsSL --max-time 15 "$url" -o /dev/null || {
    echo "error: published URL was created but did not respond: $url" >&2
    return 1
  }
}

collect_files() {
  if [[ -f "$ROOT_PATH" ]]; then
    if should_skip_storage_path "$ROOT_PATH"; then
      die "refusing to store sensitive local file: $(basename "$ROOT_PATH")"
    fi
    printf "%s\0" "$ROOT_PATH"
    return
  fi

  find "$ROOT_PATH" \
    \( -type d \( -name ".git" -o -name ".hg" -o -name ".svn" -o -name ".revdoku" -o -name ".terraform" -o -name "node_modules" \) -prune \) \
    -o -type f -print0 |
    while IFS= read -r -d '' file; do
      if should_skip_storage_path "$file"; then
        echo "Skipping sensitive or local-only file: $(relative_path_for "$file")" >&2
        continue
      fi
      printf "%s\0" "$file"
    done
}

should_skip_storage_path() {
  local file="$1"
  local rel name lower_rel lower_name secret_pattern
  rel="$(relative_path_for "$file")"
  name="$(basename "$file")"
  lower_rel="$(printf "%s" "$rel" | tr '[:upper:]' '[:lower:]')"
  lower_name="$(printf "%s" "$name" | tr '[:upper:]' '[:lower:]')"
  secret_pattern='(^|[._/-])(secret|secrets|credential|credentials|token|tokens|apikey|api[._-]?key|private[._-]?key)([._/-]|$)'

  case "$lower_name" in
    .ds_store|.env|*.pem|*.key|*.p12|*.pfx|*.crt|*.cer|*.der|*.kdb|*.jks|*.mobileprovision)
      return 0
      ;;
    .env.*)
      return 0
      ;;
  esac

  [[ "$lower_name" =~ ^id_(rsa|dsa|ecdsa|ed25519)(\.pub)?$ ]] && return 0
  [[ "$lower_name" =~ $secret_pattern || "$lower_rel" =~ $secret_pattern ]] && return 0

  return 1
}

publish_url_file=""
bucket_id_file=""

if [[ "$PUBLISH" == "true" ]]; then
  if ! has_index_file; then
    echo "No index.html found; Revdoku will publish a generated file listing." >&2
  fi
  if [[ "$UPLOAD_MODE" != "multipart" ]]; then
    publish_url_file="$(mktemp)"
    if publish_bucket_session > "$publish_url_file"; then
      publish_url="$(cat "$publish_url_file")"
      rm -f "$publish_url_file"
      verify_published_url "$publish_url"
      echo "Published: $publish_url" >&2
      print_terminal_link_hint
      printf "%s\n" "$publish_url"
      exit 0
    fi
    rm -f "$publish_url_file"
    if publication_limit_error && [[ -z "$BUCKET_ID" && -n "$LAST_PUBLISH_SESSION_BUCKET_ID" ]]; then
      BUCKET_ID="$LAST_PUBLISH_SESSION_BUCKET_ID"
    fi
    if [[ "$UPLOAD_MODE" == "direct" ]]; then
      publication_limit_error && print_publication_limit_guidance
      private_publication_limit_error && print_private_publication_limit_guidance
      die "direct publish session failed"
    fi
    if ! publish_session_fallback_allowed; then
      publication_limit_error && print_publication_limit_guidance
      private_publication_limit_error && print_private_publication_limit_guidance
      [[ "${LAST_ERROR_CODE:-}" == "PRIVATE_PUBLICATION_STORAGE_NOT_CONFIGURED" ]] && echo "Protected website publishing is not configured for this Revdoku deployment." >&2
      die "direct publish session failed"
    fi
    echo "Direct publish session failed; retrying with compatibility upload." >&2
  fi
fi

bucket_id_file="$(mktemp)"
if ! store_bucket > "$bucket_id_file"; then
  rm -f "$bucket_id_file"
  die "bucket store failed"
fi
bucket_id="$(cat "$bucket_id_file")"
rm -f "$bucket_id_file"
echo "Stored bucket: $bucket_id" >&2

if [[ "$PUBLISH" == "true" ]]; then
  publish_url_file="$(mktemp)"
  if ! publish_bucket "$bucket_id" > "$publish_url_file"; then
    rm -f "$publish_url_file"
    die "bucket publish failed"
  fi
  publish_url="$(cat "$publish_url_file")"
  rm -f "$publish_url_file"
  verify_published_url "$publish_url"
  echo "Published: $publish_url" >&2
  print_terminal_link_hint
  printf "%s\n" "$publish_url"
else
  printf "%s\n" "$bucket_id"
fi
