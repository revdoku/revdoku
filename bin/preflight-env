#!/usr/bin/env bash
#
# bin/preflight-env — shared env validation for bin/dev and bin/start.
#
# Runs every check that is independent of how Revdoku is being launched
# (dev foreman vs prod docker compose). Both bin/dev and bin/start delegate
# their config-correctness logic here so the rules live in one place.
#
# What this checks:
#   - .env.local exists in the repo root
#   - SECRET_KEY_BASE / LOCKBOX_MASTER_KEY / PREFIX_ID_SALT /
#     REVDOKU_DOC_API_KEY are present and non-blank
#   - LOCKBOX_MASTER_KEY is 64 hex chars (Lockbox demands 32 raw bytes)
#   - SECRET_KEY_BASE is at least 30 chars (Rails session signing minimum)
#   - REVDOKU_BOOTSTRAP_ADMIN_EMAIL/_PASSWORD: warns when SET (plaintext
#     credentials in .env.local are a leak surface — only needed for first
#     boot to seed the admin user; remove after first login). Hard error
#     if exactly one of the two is set. Silent when both unset.
#   - ACTIVE_STORAGE_SERVICE=amazon → AWS_ACCESS_KEY_ID /
#     AWS_SECRET_ACCESS_KEY / AWS_S3_BUCKET all set
#   - Any AI provider key (<PROVIDER>_API_KEY) is detected — warn loudly
#     when it's set to an empty string (silent treat-as-unset is the bug
#     that surfaced during Core self-host: operator pastes the line, leaves
#     the value blank, gets no feedback)
#
# Exit codes:
#   0   all checks passed (warnings may have been printed)
#   1   one or more hard errors — caller should abort
#
# Usage:
#   bin/preflight-env             # default, prints to stderr
#   bin/preflight-env --quiet     # suppress the "✓ env preflight OK" line
#                                   on the happy path; still prints failures
#
# Don't source this script. Sourcing leaks the env_value() helper and would
# pollute the caller's variable namespace. Run it as a subprocess; check $?.

set -euo pipefail

cd "$(dirname "$0")/.."

quiet=0
for arg in "$@"; do
  case "$arg" in
    --quiet|-q) quiet=1 ;;
    *) ;;
  esac
done

if [[ -t 2 && -z "${NO_COLOR:-}" ]]; then
  c_red=$'\e[31m'; c_grn=$'\e[32m'; c_ylw=$'\e[33m'; c_bld=$'\e[1m'; c_dim=$'\e[2m'; c_off=$'\e[0m'
else
  c_red=; c_grn=; c_ylw=; c_bld=; c_dim=; c_off=
fi

errors=0
warnings=0
fail()      { echo "${c_red}${c_bld}✗${c_off} $*" >&2; errors=$((errors + 1)); }
warn()      { echo "${c_ylw}!${c_off} $*" >&2; warnings=$((warnings + 1)); }
note()      { echo "${c_dim}   $*${c_off}" >&2; }
warn_note() { echo "${c_ylw}   $*${c_off}" >&2; }
heading() { echo "" >&2; echo "${c_bld}$*${c_off}" >&2; }

# Read .env.local without sourcing it — sourcing is unsafe (unquoted values,
# shell metachars, BOM bytes). A line-grep is enough to ask "is this var set
# to a non-empty value", which is what every check below needs.
env_value() {
  [[ -f .env.local ]] || return 0
  # `|| true` suppresses grep-no-match (exit 1) under `set -euo pipefail`.
  # Without it, a missing optional var (e.g. unset BOOTSTRAP_ADMIN) aborts
  # the script silently when read into a plain `var=$(env_value …)`
  # assignment — the caller still wants the empty string back, not abort.
  { grep -E "^[[:space:]]*$1=" .env.local 2>/dev/null \
    | head -1 \
    | sed -E 's/^[[:space:]]*[^=]+=//' \
    | sed -E 's/^"([^"]*)"$/\1/; s/^'"'"'([^'"'"']*)'"'"'$/\1/'; } || true
}

# Returns 0 when the var appears in .env.local, regardless of whether the
# value after `=` is empty. Used to distinguish "set to empty" (warn) from
# "absent" (silent skip).
env_present() {
  [[ -f .env.local ]] || return 1
  grep -qE "^[[:space:]]*$1=" .env.local 2>/dev/null
}

# ─── 1. .env.local present ────────────────────────────────────────────────
# Verbose because non-technical users hit this most often, and "not found"
# without context looks like noise. Spell out the name and the leading dot.
if [[ ! -f .env.local ]]; then
  # Absolute path so terminals that hyperlink file paths (iTerm2, Warp,
  # WezTerm, modern VS Code terminal) make it clickable. Falls back to
  # the literal "$(pwd)/.env.local" when realpath isn't available.
  ENV_LOCAL_ABS="$(realpath ".env.local" 2>/dev/null || echo "$(pwd)/.env.local")"
  heading "Revdoku can't start — your .env.local file is missing."
  echo "" >&2
  note "Revdoku reads all its configuration from a file called exactly:"
  note ""
  note "    ${c_bld}${ENV_LOCAL_ABS}${c_off}"
  note ""
  note "Yes — the file name starts with a DOT. (On macOS / Linux, names"
  note "starting with a dot are \"hidden\" by default in Finder / most file"
  note "browsers. Use the terminal or enable \"Show hidden files\" to see"
  note "them.)"
  note ""
  note "To create one, open a terminal in this folder and run:"
  note ""
  note "    ${c_bld}cp env.example .env.local${c_off}"
  note ""
  note "Then open the new .env.local file in any text editor and fill in the"
  note "lines marked [REQUIRED]. Instructions are inside the file."
  echo "" >&2
  exit 1
fi

# ─── 2. Required secrets (must be non-empty) ──────────────────────────────
REQUIRED_SECRETS=(
  SECRET_KEY_BASE
  LOCKBOX_MASTER_KEY
  PREFIX_ID_SALT
  REVDOKU_DOC_API_KEY
)
missing_secrets=()
for var in "${REQUIRED_SECRETS[@]}"; do
  if [[ -z "$(env_value "$var")" ]]; then
    missing_secrets+=("$var")
  fi
done
if (( ${#missing_secrets[@]} > 0 )); then
  heading "Your .env.local is missing required values."
  echo "" >&2
  note "The following lines in .env.local are blank and must be filled in:"
  note ""
  for var in "${missing_secrets[@]}"; do
    note "    ${c_bld}${var}${c_off}"
  done
  note ""
  note "Each one should be a long random string. Generate one with:"
  note ""
  note "    ${c_bld}openssl rand -hex 32${c_off}"
  note ""
  note "Paste the output after the = sign (no quotes, no spaces). See"
  note "env.example for per-variable explanations."
  echo "" >&2
  errors=$((errors + 1))
fi

# ─── 2b. Format validation ────────────────────────────────────────────────
# Lockbox needs exactly 32 raw bytes → 64 hex chars. A short value passes
# the non-empty check above but crashes Rails at first encrypted read. Catch
# it here so the operator sees a targeted fix, not a 500 after login.
lockbox_key="$(env_value LOCKBOX_MASTER_KEY)"
if [[ -n "$lockbox_key" && ! "$lockbox_key" =~ ^[0-9a-fA-F]{64}$ ]]; then
  heading "LOCKBOX_MASTER_KEY in .env.local is the wrong format."
  echo "" >&2
  note "Lockbox requires exactly 32 bytes, written as a 64-character hex"
  note "string (digits 0-9 and letters a-f only). Your value has"
  note "${c_bld}${#lockbox_key} character(s)${c_off}."
  note ""
  note "Generate a correct value with:"
  note ""
  note "    ${c_bld}openssl rand -hex 32${c_off}"
  note ""
  note "IMPORTANT: if this instance has already stored encrypted data,"
  note "changing this key makes that data permanently unreadable. If it's"
  note "a fresh install, wipe the storage volume before re-running."
  echo "" >&2
  errors=$((errors + 1))
fi

secret_key_base="$(env_value SECRET_KEY_BASE)"
if [[ -n "$secret_key_base" && ${#secret_key_base} -lt 30 ]]; then
  heading "SECRET_KEY_BASE in .env.local is too short."
  echo "" >&2
  note "Rails requires at least 30 characters for session signing; your"
  note "value has ${c_bld}${#secret_key_base} character(s)${c_off}."
  note ""
  note "Generate a correct value with:   ${c_bld}openssl rand -hex 64${c_off}"
  echo "" >&2
  errors=$((errors + 1))
fi

# ─── 3. Bootstrap admin — security warning when SET, not when unset ───────
# These two env vars are needed ONLY for the first boot, to seed an admin
# user without configuring SMTP. After the first successful login the user
# persists in the database and the env values become dead weight — but
# they're still readable as plaintext via `docker inspect`, /proc/<pid>/environ,
# `ps eww`, and any backup that includes .env.local. So:
#   BOTH set     → security warning every boot ("remove after first login")
#   ONE set      → hard error ("set both or remove both")
#   NEITHER set  → silent (could be valid post-login state OR mid-setup;
#                  preflight has no DB access to tell the difference, and
#                  the operator hits a sign-in error on first browse anyway)
admin_email="$(env_value REVDOKU_BOOTSTRAP_ADMIN_EMAIL)"
admin_password="$(env_value REVDOKU_BOOTSTRAP_ADMIN_PASSWORD)"
if [[ -n "$admin_email" && -n "$admin_password" ]]; then
  warn "REVDOKU_BOOTSTRAP_ADMIN_EMAIL / _PASSWORD set in .env.local — remove after first login (plaintext via docker inspect / /proc / backups)."
  warn_note "Changing the password env var won't rotate the admin's password — seed is idempotent by email. Use in-app change or Rails console."
elif [[ -n "$admin_email" || -n "$admin_password" ]]; then
  fail "Set BOTH REVDOKU_BOOTSTRAP_ADMIN_EMAIL and REVDOKU_BOOTSTRAP_ADMIN_PASSWORD, or REMOVE both"
fi

# ─── 4. S3 storage cross-check ────────────────────────────────────────────
if [[ "$(env_value ACTIVE_STORAGE_SERVICE)" == "amazon" ]]; then
  for var in AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_S3_BUCKET; do
    if [[ -z "$(env_value "$var")" ]]; then
      fail "$var is required when ACTIVE_STORAGE_SERVICE=amazon"
    fi
  done
fi

# ─── 5. AI provider keys: empty-string detection ──────────────────────────
# If the operator leaves OPENROUTER_API_KEY=  in .env.local, .present? in
# Rails and truthy checks in doc-api both correctly treat it as unset, but
# silently — the operator gets no feedback and assumes the key was honoured.
# Mirrors the boot-time audit in apps/web/config/initializers/01_ai_provider_keys_audit.rb,
# but fires earlier (before Rails even loads), so the foreman / docker logs
# show the warning at the first opportunity.
AI_PROVIDER_VARS=(
  OPENROUTER_API_KEY
  OPENAI_API_KEY
  ANTHROPIC_API_KEY
  GOOGLE_CLOUD_API_KEY
  AWS_BEDROCK_API_KEY
)
for var in "${AI_PROVIDER_VARS[@]}"; do
  if env_present "$var" && [[ -z "$(env_value "$var")" ]]; then
    warn "$var in .env.local is set to an empty string"
    note "It will be treated as 'not configured' (no AI inspections via"
    note "this provider). Either fill in a real key or comment the line"
    note "out. Per-account BYOK keys (Account → AI → Providers) still"
    note "work independently."
  fi
done

# ─── Result ───────────────────────────────────────────────────────────────
if (( errors > 0 )); then
  echo "" >&2
  echo "${c_red}${c_bld}env preflight failed with $errors error(s).${c_off} Fix the items above and re-run." >&2
  exit 1
fi

if (( quiet == 0 )); then
  if (( warnings > 0 )); then
    echo "${c_grn}${c_bld}✓${c_off} env preflight OK (${warnings} warning(s) above)" >&2
  else
    echo "${c_grn}${c_bld}✓${c_off} env preflight OK" >&2
  fi
fi
