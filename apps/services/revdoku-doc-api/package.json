{
  "name": "@revdoku/doc-api",
  "version": "1.0.0",
  "main": "build/server.js",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsc && node resolve-module-alias.js",
    "start": "node build/server.js",
    "dev": "mkdir -p logs && NODE_ENV=development tsx watch src/server.ts 2>&1 | tee -a logs/development.log | pino-pretty --colorize",
    "test": "NODE_ENV=test tsx --test 'tests/**/*.test.ts'",
    "test:watch": "NODE_ENV=test tsx --test --watch 'tests/**/*.test.ts'",
    "strip-ee": "node scripts/strip-ee-blocks.mjs src",
    "strip-ee:at": "node scripts/strip-ee-blocks.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.0.1",
    "@revdoku/lib": "file:../../shared/js-packages/revdoku-lib",
    "@sinclair/typebox": "^0.34.35",
    "@types/diff": "^7.0.2",
    "canvas": "^3.1.0",
    "diff": "^8.0.3",
    "dotenv": "^16.5.0",
    "exifr": "^7.1.3",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.0",
    "handlebars": "^4.7.8",
    "jsonrepair": "^3.13.3",
    "jspdf": "^4.2.1",
    "openai": "^5.3.0",
    "pdf-to-image-generator": "1.0.5",
    "pdfjs-dist": "^5.3.31",
    "puppeteer": "^24.10.1",
    "sharp": "^0.34.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/pngjs": "^6.0.5",
    "nodemon": "^3.1.10",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^11.3.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "preprocess": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3"
  }
}
