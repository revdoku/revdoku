#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then

  # Database restore: use deployment/full-stack/scripts/restore-db.sh manually.
  # The Docker volume persists databases across deploys; if it's missing,
  # db:prepare creates a fresh one and you restore deliberately.
  ./bin/rails db:prepare

  # Start revdoku-doc-api with auto-restart loop (exponential backoff).
  # The compiled server.js lives at build/server.js when tsc was rooted
  # at src/ (Core build with ee/ stripped) or build/src/server.js when
  # tsc's rootDir lifted to the project root (Enterprise build with
  # ee/lib/*.ts included). Detect once at boot.
  if [ -f /app/revdoku-doc-api/build/src/server.js ]; then
    DOC_API_SERVER=build/src/server.js
  elif [ -f /app/revdoku-doc-api/build/server.js ]; then
    DOC_API_SERVER=build/server.js
  else
    DOC_API_SERVER=
  fi

  if [ -n "$DOC_API_SERVER" ]; then
    (
      BACKOFF=2
      while true; do
        echo "Starting revdoku-doc-api ($DOC_API_SERVER, backoff=${BACKOFF}s)..."
        START_TIME=$(date +%s)
        cd /app/revdoku-doc-api
        NODE_ENV=production PORT=4001 node "$DOC_API_SERVER" 2>&1 | sed -u 's/^/[revdoku-doc-api] /'
        EXIT_CODE=${PIPESTATUS[0]}
        ELAPSED=$(( $(date +%s) - START_TIME ))
        echo "revdoku-doc-api exited with code $EXIT_CODE after ${ELAPSED}s, restarting in ${BACKOFF}s..."
        sleep $BACKOFF
        # If revdoku-doc-api ran for >60s, it was healthy — reset backoff
        if [ $ELAPSED -gt 60 ]; then
          BACKOFF=2
        else
          BACKOFF=$(( BACKOFF * 2 ))
          [ $BACKOFF -gt 30 ] && BACKOFF=30
        fi
      done
    ) &
    REVDOKU_DOC_API_LOOP_PID=$!

    # Wait for revdoku-doc-api health (up to 30s)
    for i in $(seq 1 30); do
      if curl -sf http://localhost:4001/api/v1/health > /dev/null 2>&1; then
        echo "revdoku-doc-api is ready (took ${i}s)"
        break
      fi
      if [ $i -eq 30 ]; then
        echo "ERROR: revdoku-doc-api did not become healthy within 30s"
        if ! kill -0 $REVDOKU_DOC_API_LOOP_PID 2>/dev/null; then
          echo "ERROR: revdoku-doc-api process has died — check [revdoku-doc-api] log lines above"
        else
          echo "WARNING: revdoku-doc-api loop running but not healthy — likely crash-looping"
        fi
      fi
      sleep 1
    done

    # Signal-forwarding wrapper: run Rails in foreground, clean up on SIGTERM/SIGINT
    cleanup() {
      kill $REVDOKU_DOC_API_LOOP_PID $RAILS_PID 2>/dev/null
      wait $REVDOKU_DOC_API_LOOP_PID $RAILS_PID 2>/dev/null
    }
    trap cleanup SIGTERM SIGINT

    "${@}" &
    RAILS_PID=$!
    wait $RAILS_PID
    exit $?
  fi
fi

exec "${@}"
