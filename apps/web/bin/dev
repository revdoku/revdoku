#!/usr/bin/env sh

if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# Idempotent "create-if-missing → migrate" — safe on every boot. Without
# it, a wipe-build-core leaves Rails booting against a missing schema and
# the lazy template seed crashes on the first request.
bin/rails db:prepare

# Bootsnap caches compiled iseq by absolute path; rsync -a from
# build-core preserves source mtimes, so bootsnap's cache key matches a
# stale file's bytecode after a code update. Symptom: new method calls
# raise ArgumentError "wrong number of arguments" against the previous
# signature. Wiping is cheap (~hundreds of ms once) and avoids the bug
# class entirely.
rm -rf tmp/cache/bootsnap

# Default to port 3000 if not specified
export PORT="${PORT:-3000}"

# Let the debug gem allow remote connections,
# but avoid loading until `debugger` is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

exec foreman start -f Procfile.dev "$@"
