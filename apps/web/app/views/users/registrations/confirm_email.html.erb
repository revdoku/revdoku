<div class="max-w-md w-full space-y-8">
  <div>
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 dark:text-white">
      Confirm your email
    </h2>
    <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
      We sent a 6-digit code to <strong><%= @email %></strong>
    </p>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 rounded-md p-4">
      <p class="text-sm text-green-700"><%= flash[:notice] %></p>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <p class="text-sm text-red-700"><%= flash[:alert] %></p>
    </div>
  <% end %>

  <%= form_tag(users_verify_confirmation_path, method: :post, class: "mt-8 space-y-6") do %>
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <%= hidden_field_tag :email, @email %>

    <div class="rounded-md shadow-sm">
      <div>
        <label for="code" class="sr-only">Verification code</label>
        <input id="code" name="code" type="text" inputmode="numeric" pattern="[0-9]*"
               autofocus autocomplete="one-time-code" maxlength="6"
               placeholder="6-digit code"
               class="appearance-none rounded-md relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white dark:bg-gray-800 text-center text-lg tracking-widest focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" />
      </div>
    </div>

    <div>
      <button type="submit"
              class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer">
        Confirm
      </button>
    </div>
  <% end %>

  <div class="text-center space-y-2">
    <%= button_to "Resend code", users_resend_confirmation_path, method: :post, class: "text-sm font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300 bg-transparent border-none cursor-pointer" %>
    <br>
    <%= link_to "Back to sign up", new_user_registration_path, class: "text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300" %>
  </div>
</div>
