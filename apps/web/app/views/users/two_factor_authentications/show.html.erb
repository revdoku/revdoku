<div class="max-w-md w-full space-y-8">
  <% if current_user.two_factor_enabled? %>
    <%# === Management mode: 2FA is enabled === %>
    <div>
      <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 dark:text-white">
        Two-factor authentication
      </h2>
    </div>

    <% if flash[:notice] %>
      <div class="bg-green-50 border border-green-200 rounded-md p-4">
        <p class="text-sm text-green-700"><%= flash[:notice] %></p>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <p class="text-sm text-red-700"><%= flash[:alert] %></p>
      </div>
    <% end %>

    <div class="bg-green-50 border border-green-200 rounded-md p-4 flex items-center">
      <svg class="h-5 w-5 text-green-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      <p class="text-sm font-medium text-green-800">Two-factor authentication is enabled</p>
    </div>

    <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
      <h3 class="text-base font-medium text-gray-900 dark:text-white mb-4">Disable two-factor authentication</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        Enter a code from your authenticator app to disable 2FA.
      </p>

      <%= form_tag(users_two_factor_authentication_path, method: :delete, class: "space-y-4", data: { turbo: false }) do %>

        <div class="rounded-md shadow-sm">
          <label for="otp_attempt" class="sr-only">Authentication code</label>
          <input id="otp_attempt" name="otp_attempt" type="text" inputmode="numeric" pattern="[0-9]*"
                 autofocus autocomplete="one-time-code" maxlength="8"
                 placeholder="Authentication code"
                 class="appearance-none rounded-md relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white dark:bg-gray-800 text-center text-lg tracking-widest focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" />
        </div>

        <button type="submit"
                class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer">
          Disable two-factor authentication
        </button>
      <% end %>
    </div>

  <% else %>
    <%# === Setup mode: multi-step wizard === %>
    <div data-controller="two-factor-setup" data-two-factor-setup-current-value="<%= flash[:alert] ? 2 : 1 %>">

      <%# Step indicator %>
      <div class="flex items-center justify-center mb-8 mt-6">
        <div data-two-factor-setup-target="indicator"
             class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-blue-600 text-white">
          1
        </div>
        <div class="w-16 h-0.5 bg-gray-300 dark:bg-gray-600"></div>
        <div data-two-factor-setup-target="indicator"
             class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-gray-200 dark:bg-gray-700 text-gray-600 dark:text-gray-400">
          2
        </div>
      </div>

      <%# Step 1: Prepare %>
      <div data-two-factor-setup-target="step" class="space-y-6">
        <div class="text-center">
          <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white">
            Set up two-factor authentication
          </h2>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Add an extra layer of security to your account
          </p>
        </div>

        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 space-y-4">
          <h3 class="text-base font-semibold text-gray-900 dark:text-white">Before you begin</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            You'll need an authenticator app on your phone or tablet. It generates temporary codes used to verify your identity.
          </p>

          <div class="space-y-3">
            <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Recommended apps:</p>
            <ul class="space-y-2">
              <li class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                <svg class="h-4 w-4 text-green-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Google Authenticator
              </li>
              <li class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                <svg class="h-4 w-4 text-green-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Authy
              </li>
              <li class="flex items-center text-sm text-gray-600 dark:text-gray-400">
                <svg class="h-4 w-4 text-green-500 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                1Password
              </li>
            </ul>
          </div>
        </div>

        <button type="button"
                data-action="two-factor-setup#next"
                class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer">
          I have an authenticator app &rarr;
        </button>
      </div>

      <%# Step 2: Scan QR & Verify %>
      <div data-two-factor-setup-target="step" class="hidden space-y-6">
        <div class="text-center">
          <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white">
            Scan QR code & verify
          </h2>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Scan the code below with your authenticator app
          </p>
        </div>

        <% if flash[:alert] %>
          <div class="bg-red-50 border border-red-200 rounded-md p-4">
            <p class="text-sm text-red-700"><%= flash[:alert] %></p>
          </div>
        <% end %>

        <%# QR Code %>
        <div class="flex justify-center">
          <div class="bg-white p-4 rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm inline-block">
            <%= @qr_code.html_safe %>
          </div>
        </div>

        <%# Manual entry key %>
        <div class="text-center">
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Or enter this key manually:</p>
          <code class="text-sm font-mono font-bold text-gray-800 dark:text-gray-200 bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded select-all">
            <%= current_user.otp_secret %>
          </code>
        </div>

        <%# Verification form %>
        <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            Enter the 6-digit code from your authenticator app to complete setup.
          </p>

          <%= form_tag(users_two_factor_authentication_path, method: :post, class: "space-y-4", data: { turbo: false }) do %>

            <div class="rounded-md shadow-sm">
              <label for="otp_attempt" class="sr-only">Authentication code</label>
              <input id="otp_attempt" name="otp_attempt" type="text" inputmode="numeric" pattern="[0-9]*"
                     autofocus autocomplete="one-time-code" maxlength="6"
                     placeholder="6-digit code"
                     class="appearance-none rounded-md relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white dark:bg-gray-800 text-center text-lg tracking-widest focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" />
            </div>

            <div class="flex gap-3">
              <button type="button"
                      data-action="two-factor-setup#previous"
                      class="flex-1 py-2 px-4 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer">
                &larr; Back
              </button>
              <button type="submit"
                      class="flex-1 py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer">
                Verify & Enable
              </button>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  <% end %>

  <div class="text-center">
    <%= link_to "Back to dashboard", root_path, class: "text-sm font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300" %>
  </div>
</div>
