<div class="max-w-md w-full space-y-8"
     data-controller="backup-codes"
     data-backup-codes-codes-value="<%= @backup_codes.join("\n") %>">

  <%# Step indicator showing step 3 complete %>
  <div class="flex items-center justify-center mt-6">
    <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-blue-600 text-white">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
    </div>
    <div class="w-16 h-0.5 bg-blue-600"></div>
    <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-blue-600 text-white">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
    </div>
    <div class="w-16 h-0.5 bg-blue-600"></div>
    <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold bg-blue-600 text-white">
      3
    </div>
  </div>

  <div class="text-center">
    <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white">
      Two-factor authentication enabled
    </h2>
    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
      Your account is now protected with 2FA
    </p>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 rounded-md p-4">
      <p class="text-sm text-green-700"><%= flash[:notice] %></p>
    </div>
  <% end %>

  <div class="bg-amber-50 border border-amber-200 rounded-md p-4">
    <div class="flex">
      <svg class="h-5 w-5 text-amber-600 mr-3 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <div>
        <p class="text-sm font-medium text-amber-800">Save your backup codes now</p>
        <p class="text-xs text-amber-700 mt-1">
          These codes will not be shown again. Store them in a safe place. If you lose your authenticator device, you can use one of these codes to sign in.
        </p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-2 px-4">
    <% @backup_codes.each do |code| %>
      <code class="text-sm font-mono font-bold text-gray-800 dark:text-gray-200 bg-gray-100 dark:bg-gray-800 px-3 py-1.5 rounded text-center"><%= code %></code>
    <% end %>
  </div>

  <%# Save actions %>
  <div class="flex gap-2 justify-center">
    <button type="button"
            data-action="backup-codes#download"
            class="inline-flex items-center gap-1.5 py-2 px-4 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      Download
    </button>
    <button type="button"
            data-action="backup-codes#copy"
            class="inline-flex items-center gap-1.5 py-2 px-4 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      Copy
    </button>
    <button type="button"
            data-action="backup-codes#print"
            class="inline-flex items-center gap-1.5 py-2 px-4 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
      </svg>
      Print
    </button>
  </div>

  <%# Saved confirmation %>
  <div data-backup-codes-target="savedNotice" class="hidden">
    <div class="bg-green-50 border border-green-200 rounded-md p-3 flex items-center justify-center">
      <svg class="h-4 w-4 text-green-600 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      <p class="text-sm font-medium text-green-700">Backup codes saved</p>
    </div>
  </div>

  <%# Continue button - disabled until codes are saved %>
  <div class="text-center pt-2">
    <%= link_to "Continue to dashboard", root_path,
        data: { backup_codes_target: "continueButton" },
        class: "group relative inline-flex justify-center py-2 px-8 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 opacity-50 cursor-not-allowed pointer-events-none" %>
  </div>
</div>
