<%# Shared legal / policy links partial.
     style: :footer (default) — spaced links for footer use
     style: :inline — comma-separated prose for sign-up/sign-in forms
     class: optional custom CSS class for link elements

     When no legal URLs are configured (self-host default), the footer
     renders a neutral open-source attribution instead of broken
     placeholder links. Each URL is individually optional — a deployment
     that has Terms but not Privacy just shows Terms.
%>
<% style = local_assigns.fetch(:style, :footer) %>
<% link_class = local_assigns.fetch(:class, nil) %>
<% policy_links = {
     "Terms of Service" => Revdoku.terms_url,
     "Privacy Policy"   => Revdoku.privacy_url
   }.compact %>

<% if style == :inline %>
  <% tos = Revdoku.terms_url %>
  <% privacy = Revdoku.privacy_url %>
  <% if tos && privacy %>
    <a href="<%= tos %>" target="_blank" rel="noopener noreferrer" class="<%= link_class || 'underline hover:text-gray-700 dark:hover:text-gray-300' %>">Terms of Service</a>
    and
    <a href="<%= privacy %>" target="_blank" rel="noopener noreferrer" class="<%= link_class || 'underline hover:text-gray-700 dark:hover:text-gray-300' %>">Privacy Policy</a>
  <% end %>
<% elsif policy_links.any? %>
  <% policy_links.each_with_index do |(label, url), i| %>
    <% if i > 0 %><span>&middot;</span><% end %>
    <a href="<%= url %>" target="_blank" rel="noopener noreferrer" class="<%= link_class || 'hover:text-gray-600 dark:hover:text-gray-300' %>"><%= label %></a>
  <% end %>
<% else %>
  <span class="<%= link_class || 'text-gray-500 dark:text-gray-500' %>">
    Running Revdoku Open Source &mdash;
    <a href="<%= Revdoku.source_code_url %>" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-700 dark:hover:text-gray-300"><%= Revdoku.source_code_url.sub(%r{\Ahttps?://}, "") %></a>
  </span>
<% end %>
