<div class="max-w-md w-full space-y-4 sm:space-y-8">
  <%# Heading omitted on purpose — the Google button + email form make the
      page's intent obvious, and removing the h2 saves a full hero-row of
      vertical space on mobile. %>
  <h2 class="sr-only">Create New Account</h2>

  <%#
    Data region is inferred from the deployment — the signup page on app.revdoku.com
    is always the US region; when EU goes live on its own deployment that signup
    page will auto-render with the EU label. Nothing for the user to choose.
    The badge + consent copy live below the submit button to keep the form's
    first-paint vertical space tight; screen readers still encounter them
    before the "Already have an account?" link.
  %>
  <% current_region = (Revdoku.respond_to?(:current_data_region) ? Revdoku.current_data_region : nil) %>

  <div class="space-y-4 sm:space-y-6">
    <% if Revdoku.google_auth_enabled? %>
      <div>
        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "w-full inline-flex justify-center items-center py-3 px-4 border border-[#747775] dark:border-gray-600 rounded-md shadow-sm bg-white dark:bg-gray-800 text-base font-medium text-[#1F1F1F] dark:text-white hover:bg-gray-50 dark:hover:bg-gray-700" do %>
          <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Sign up with Google
        <% end %>
      </div>
    <% end %>

    <% if Revdoku.google_auth_enabled? %>
      <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300 dark:border-gray-700"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-gray-50 dark:bg-gray-950 text-gray-500 dark:text-gray-400">Or continue with email</span>
        </div>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6", data: { turbo: false } }) do |f| %>
      <% if resource.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-md p-3 mb-4">
          <% resource.errors.full_messages.each do |message| %>
            <p class="text-sm text-red-700"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div class="rounded-md -space-y-px">
        <div class="flex">
          <div class="w-1/2">
            <%= f.label :first_name, class: "sr-only" %>
            <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name",
                placeholder: "First name", required: true,
                class: "appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-tl-md focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" %>
          </div>
          <div class="w-1/2">
            <%= f.label :last_name, class: "sr-only" %>
            <%= f.text_field :last_name, autocomplete: "family-name",
                placeholder: "Last name", required: true,
                class: "appearance-none rounded-none relative block w-full px-3 py-2 border border-l-0 border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-tr-md focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" %>
          </div>
        </div>
        <div>
          <%= f.label :email, class: "sr-only" %>
          <%= f.email_field :email, autocomplete: "email",
              placeholder: "Your work email", required: true,
              class: "appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 #{Revdoku.password_based_login? ? '' : 'rounded-b-md'} focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" %>
        </div>

        <% if Revdoku.password_based_login? %>
          <div>
            <%= f.label :password, class: "sr-only" %>
            <%= f.password_field :password, autocomplete: "new-password",
                placeholder: "Password (min 8 characters)", required: true, minlength: 8,
                class: "appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" %>
          </div>
          <div>
            <%= f.label :password_confirmation, class: "sr-only" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                placeholder: "Confirm password", required: true, minlength: 8,
                class: "appearance-none rounded-none relative block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white bg-white dark:bg-gray-800 rounded-b-md focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 sm:text-sm" %>
          </div>
        <% end %>
      </div>

      <%= turnstile_widget %>

      <div>
        <%= f.submit (Revdoku.password_based_login? ? "Create account" : "Sign up with Email"),
            class: "group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <% if Revdoku.legal_urls_configured? %>
    <p class="mt-4 text-center text-xs text-gray-500 dark:text-gray-400">
      By signing up, you agree to our
      <%= render "shared/legal_links", style: :inline %><% if current_region %>,
      and that your data will be stored and processed in the <strong class="font-medium"><%= current_region["name"] %></strong><% end %>.
      <% if defined?(Revdoku::SUPPORT_EMAIL) && current_region %>
        Need a different region? <%= mail_to Revdoku::SUPPORT_EMAIL, "Contact us", subject: "[Data region request]", class: "text-blue-600 hover:text-blue-500 dark:text-blue-400 underline" %>.
      <% end %>
    </p>
  <% end %>

  <p class="mt-6 text-center text-sm text-gray-600 dark:text-gray-400">
    Already have an account?
    <%= link_to "Sign in", new_user_session_path, class: "font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300" %>
  </p>
</div>
