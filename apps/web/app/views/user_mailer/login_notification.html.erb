<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 480px; margin: 0 auto; padding: 40px 20px;">
  <h1 style="color: #2563eb; font-size: 24px; font-weight: bold; letter-spacing: 0.05em; margin-bottom: 24px;">REVDOKU</h1>

  <p style="color: #374151; font-size: 16px; margin-bottom: 16px;">
    Hi <%= @user.first_name.presence || "there" %>,
  </p>

  <% if @new_device %>
    <p style="color: #374151; font-size: 16px; margin-bottom: 24px;">
      Your Revdoku account <strong><%= @user_email %></strong> was just used to sign in from a new or unrecognized device.
    </p>
  <% else %>
    <p style="color: #374151; font-size: 16px; margin-bottom: 24px;">
      We detected a sign-in to your Revdoku account <strong><%= @user_email %></strong>.
    </p>
  <% end %>

  <table style="width: 100%; background-color: #f3f4f6; border-radius: 8px; padding: 16px; margin-bottom: 24px; border-collapse: collapse;">
    <tr>
      <td style="padding: 8px 16px; color: #6b7280; font-size: 14px;">Date &amp; Time</td>
      <td style="padding: 8px 16px; color: #111827; font-size: 14px;"><%= @signed_in_at.strftime("%B %d, %Y at %I:%M %p %Z") %></td>
    </tr>
    <tr>
      <td style="padding: 8px 16px; color: #6b7280; font-size: 14px;">Device</td>
      <td style="padding: 8px 16px; color: #111827; font-size: 14px;"><%= @device_summary %></td>
    </tr>
    <% if @show_ip %>
      <tr>
        <td style="padding: 8px 16px; color: #6b7280; font-size: 14px;">IP Address</td>
        <td style="padding: 8px 16px; color: #111827; font-size: 14px;"><%= @ip_address %></td>
      </tr>
    <% end %>
  </table>

  <p style="color: #374151; font-size: 14px; font-weight: bold; margin-bottom: 8px;">
    Don't recognize this activity?
  </p>

  <p style="color: #6b7280; font-size: 14px; margin-bottom: 24px;">
    If you think your account may have been compromised, please contact us immediately at <a href="mailto:support@revdoku.com" style="color: #2563eb;">support@revdoku.com</a>.
  </p>

  <p style="color: #9ca3af; font-size: 12px; border-top: 1px solid #e5e7eb; padding-top: 16px;">
    We were unable to determine if you had previously signed in with this device before. This notification is common if you are signing in from a new device or a new browser, have deleted your cookies, or are accessing your account in incognito mode.
  </p>
</div>
