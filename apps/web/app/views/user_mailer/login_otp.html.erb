<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 480px; margin: 0 auto; padding: 40px 20px;">
  <h1 style="color: #2563eb; font-size: 24px; font-weight: bold; letter-spacing: 0.05em; margin-bottom: 24px;">REVDOKU</h1>

  <p style="color: #374151; font-size: 16px; margin-bottom: 16px;">
    Hi <%= @user.first_name.presence || "there" %>,
  </p>

  <p style="color: #374151; font-size: 16px; margin-bottom: 24px;">
    Your login verification code is:
  </p>

  <div style="background-color: #f3f4f6; border-radius: 8px; padding: 20px; text-align: center; margin-bottom: 24px;">
    <span style="font-size: 32px; font-weight: bold; letter-spacing: 8px; color: #111827;"><%= @code %></span>
  </div>

  <p style="color: #6b7280; font-size: 14px; margin-bottom: 8px;">
    This code expires in 10 minutes.
  </p>

  <p style="color: #6b7280; font-size: 14px;">
    If you didn't request this code, you can safely ignore this email.
  </p>

  <p style="color: #f3f4f6; font-size: 1px; line-height: 1px; margin: 0;">@app.revdoku.com #<%= @code %></p>
</div>
