<div class="max-w-md w-full space-y-8">
  <div>
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 dark:text-white">
      Choose an account
    </h2>
    <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
      Select which account to sign in to
    </p>
  </div>

  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <p class="text-sm text-red-700"><%= flash[:alert] %></p>
    </div>
  <% end %>

  <div class="mt-8 space-y-3">
    <% @accounts.each do |account| %>
      <%= form_tag(choose_account_path, method: :post) do %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= hidden_field_tag :account_id, account.id %>
        <button type="submit"
                class="w-full flex items-center justify-between px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer">
          <div class="flex items-center space-x-3">
            <div class="flex-shrink-0 h-10 w-10 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
              <% if account.personal? %>
                <svg class="h-5 w-5 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              <% else %>
                <svg class="h-5 w-5 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              <% end %>
            </div>
            <div class="text-left">
              <div class="text-sm font-medium text-gray-900 dark:text-white"><%= account.name %></div>
              <div class="text-xs text-gray-500 dark:text-gray-400">
                <% if account.personal? %>
                  Personal account
                <% else %>
                  Team &middot; <%= account.users.count %> <%= "member".pluralize(account.users.count) %>
                <% end %>
              </div>
            </div>
          </div>
          <svg class="h-5 w-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      <% end %>
    <% end %>
  </div>

  <div class="text-center pt-4">
    <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300" %>
  </div>
</div>
