# Revdoku self-host configuration.
#
#   1.  cp env.example .env.local
#   2.  Fill in the [REQUIRED] values below.
#   3.  ./bin/start
#
# Revdoku reads .env.local, never this file. Anything not listed uses a
# sensible default — only touch [OPTIONAL] entries when you need them.


# ════════════════════════════════════════════════════════════════════════
# [REQUIRED] — Revdoku won't start without these.
# ════════════════════════════════════════════════════════════════════════

# Four independent random secrets. Each protects a different layer
# (session signing / data encryption / public-URL hashing / inter-service
# auth). Generate ALL FOUR separately — never reuse a value.
#
#   openssl rand -hex 64    # for SECRET_KEY_BASE
#   openssl rand -hex 32    # for the other three
#
# LOCKBOX_MASTER_KEY decrypts every encrypted field — losing or changing
# it makes existing data permanently unreadable. Store it safely.
SECRET_KEY_BASE=
LOCKBOX_MASTER_KEY=
PREFIX_ID_SALT=
REVDOKU_DOC_API_KEY=

# First admin user, created on first boot. Use a real email; password
# must be 8+ chars. Safe to remove after first sign-in.
REVDOKU_BOOTSTRAP_ADMIN_EMAIL=
REVDOKU_BOOTSTRAP_ADMIN_PASSWORD=


# ════════════════════════════════════════════════════════════════════════
# AI providers — recommended setup is in-app, NOT here.
# ════════════════════════════════════════════════════════════════════════
#
# Skip this section. After first sign-in go to Account → AI → Providers
# and paste your key there — stored encrypted per-account, no restart
# needed, works for every member.
#
# The env vars below exist only as an operator-wide fallback (shared key
# for everyone, no per-account setup). Per-account keys take precedence
# when both are present.
#
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_CLOUD_API_KEY=
# AWS_BEDROCK_API_KEY=
# AWS_BEDROCK_BASE_URL=


# ════════════════════════════════════════════════════════════════════════
# [OPTIONAL] — uncomment only what you need.
# ════════════════════════════════════════════════════════════════════════

# Sign-in mode. `password_no_confirmation` works offline (single-user box).
# `password` adds email confirmation — needs working SMTP below.
REVDOKU_LOGIN_MODE=password_no_confirmation

# SMTP — only required for `password` login mode, password resets, invites.
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_DOMAIN=

# Local port + public URL the app advertises in outbound emails.
# REVDOKU_PORT=3000
# APP_HOST=your.domain.example
# APP_PROTOCOL=https

# HTTPS-only mode. Enable only when a TLS-terminating proxy (nginx,
# Caddy, Cloudflare, …) is in front — otherwise the browser can't reach you.
# REVDOKU_FORCE_SSL=true

# File storage. Default: Docker volume `revdoku_storage` (zero setup;
# `docker compose down -v` WIPES it). For S3 or any S3-compatible service
# (MinIO, R2, B2, DigitalOcean Spaces), set the block below.
# ACTIVE_STORAGE_SERVICE=amazon
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=
# AWS_S3_ENDPOINT=                # only for S3-compatible (non-AWS) services

# Override the container image (forks that publish to a different GHCR owner).
# REVDOKU_IMAGE=ghcr.io/your-org/revdoku:latest

# Footer policy links. Leave blank for a neutral GitHub attribution.
# Don't point at revdoku.com — those govern the hosted SaaS, not your install.
# Starter copy at docs/LEGAL_TEMPLATE.md.
# REVDOKU_TERMS_URL=https://yourcompany.com/terms
# REVDOKU_PRIVACY_URL=https://yourcompany.com/privacy
# REVDOKU_SOURCE_CODE_URL=https://github.com/revdoku/revdoku
